BRASPAG_WEBHOOK_SECRET="seu-webhook-secret"
BRASPAG_BENEFICIARY_AGENCY="0001"
BRASPAG_BENEFICIARY_ACCOUNT="123456"
BRASPAG_BENEFICIARY_NAME="Seu Nome LTDA"

# TradingView Webhook Secret
TRADINGVIEW_WEBHOOK_SECRET="seu-webhook-secret"

# WhatsApp Integration (Twilio)
TWILIO_ACCOUNT_SID="seu-account-sid"

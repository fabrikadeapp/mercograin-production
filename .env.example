# Database
DATABASE_URL="postgresql://user:password@localhost:5432/mercograin"

# NextAuth
NEXTAUTH_SECRET="sua-chave-secreta-aqui-mude-em-producao"
NEXTAUTH_URL="http://localhost:3000"

# Email transacional
# Provider preferido: Resend (https://resend.com). Domínio precisa ser verificado.
# Se RESEND_API_KEY ausente, sistema cai pra SMTP (EMAIL_PASSWORD via Gmail) ou log-only.
RESEND_API_KEY=""
EMAIL_FROM="PHB Grain <noreply@profitsync.ia.br>"
# Fallback SMTP (Gmail) — usado apenas se RESEND_API_KEY ausente.
EMAIL_FROM_SMTP="seu-email@gmail.com"
EMAIL_PASSWORD="sua-senha-app-gmail"

# Redis (para cache, rate limiting, idempotência)
REDIS_URL="redis://localhost:6379"

# Braspag Integration (Boletos Reais)
BRASPAG_MERCHANT_ID="seu-merchant-id"
BRASPAG_MERCHANT_KEY="sua-merchant-key"
BRASPAG_API_URL="https://api.braspag.com.br"
BRASPAG_WEBHOOK_SECRET="seu-webhook-secret"
BRASPAG_BENEFICIARY_AGENCY="0001"
BRASPAG_BENEFICIARY_ACCOUNT="123456"
BRASPAG_BENEFICIARY_NAME="Seu Nome LTDA"

# TradingView Webhook Secret
TRADINGVIEW_WEBHOOK_SECRET="seu-webhook-secret"

# WhatsApp Integration (Twilio)
TWILIO_ACCOUNT_SID="seu-account-sid"
TWILIO_AUTH_TOKEN="seu-auth-token"
TWILIO_WHATSAPP_NUMBER="+5511999999999"

# Cron job — sync diário CEPEA + BCB PTAX (/api/cron/sync-cotacoes)
# Gerar com: openssl rand -hex 32
# Mesmo valor em GitHub Secrets (CRON_SECRET) e Railway env vars.
CRON_SECRET=""

# Sentry (Observabilidade) — OPCIONAL. Sem DSN, observabilidade desabilita.
# NEXT_PUBLIC_SENTRY_DSN é exposto ao client; SENTRY_DSN só ao server.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
# SENTRY_AUTH_TOKEN só é necessário em build/CI pra upload de source maps.
SENTRY_AUTH_TOKEN=""

# Supabase Storage (uploads de logos e assets)
# Bucket público criado: phb-grain-uploads (2MB, PNG/JPG/SVG/WebP).
# Service role key é SECRETA — só no server, nunca exposta ao client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET_UPLOADS=phb-grain-uploads

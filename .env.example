# DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/mercograin"

# AUTHENTICATION
NEXTAUTH_SECRET="gerar-com-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# TRADINGVIEW WEBHOOKS
TRADINGVIEW_WEBHOOK_SECRET="seu-secret-aleatorio-32-caracteres"

# INVESTING.COM SCRAPING
INVESTING_COM_ENABLED=true
INVESTING_COM_CACHE_MINUTES=60

# REDIS (Railway)
REDIS_URL="redis://localhost:6379"

# BRASPAG (Boletos)
BRASPAG_MERCHANT_ID="seu-merchant-id"
BRASPAG_API_KEY="sua-api-key"
BRASPAG_ENVIRONMENT="sandbox"

# TWILIO (WhatsApp)
TWILIO_ACCOUNT_SID="seu-account-sid"
TWILIO_AUTH_TOKEN="seu-auth-token"
TWILIO_PHONE_NUMBER="+5511999999999"

# SIGNATURELY (Assinatura Eletrônica)
SIGNATURELY_API_KEY="sua-api-key"

# SENDGRID (Email)
SENDGRID_API_KEY="seu-api-key"

# SENTRY (Monitoramento)
SENTRY_DSN="https://seu-sentry-dsn"
NEXT_PUBLIC_SENTRY_ENV="development"

# APP
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTENTICAÇÃO & USUÁRIOS
// ============================================

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  senha            String // Hash bcrypt
  nome             String
  role             String   @default("user") // 'admin' | 'user' | 'viewer'
  emailVerificado  Boolean  @default(false)
  stripeCustomerId String?  @unique
  criadoEm         DateTime @default(now())
  atualizadoEm     DateTime @updatedAt

  // 2FA TOTP (S2 M10)
  totpSecret              String?
  totpEnabled             Boolean                  @default(false)
  totpVerifiedAt          DateTime?
  recoveryCodes           String[]                 @default([])

  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  classificados           Classificado[]           @relation("ClassificadoAutor")
  pushSubscriptions       PushSubscription[]
  pending2FA              Pending2FA[]

  // Workspaces
  workspacesOwned      Workspace[]       @relation("WorkspaceOwner")
  workspaceMemberships WorkspaceMember[]

  // Compliance (Epic 5)
  aprovacoesSolicitadas Aprovacao[]        @relation("AprovacaoSolicitante")
  aprovacaoDecisoes     AprovacaoDecisao[]

  @@index([email])
}

// ============================================
// WORKSPACES (Multi-tenancy v2)
// ============================================

model Workspace {
  id      String @id @default(cuid())
  name    String
  slug    String @unique
  ownerId String
  owner   User   @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  members      WorkspaceMember[]
  empresa      DadosEmpresa?
  subscription Subscription?

  // Relações migradas de usuarioId → workspaceId
  clientes              Cliente[]
  propostas             Proposta[]
  contratos             Contrato[]
  boletos               Boleto[]
  classificados         Classificado[]
  alertasPreco          AlertaPreco[]
  contratosFuturos      ContratoFuturo[]
  fornecedores          Fornecedor[]
  templatesContrato     ContratoTemplate[]
  armazens              Armazem[]
  motoristas            Motorista[]
  ordensCarga           OrdemCarga[]
  // Operação Física (Epic 2)
  safras                Safra[]
  tabelasClassificacao  TabelaClassificacao[]
  balancas              Balanca[]
  lotesEstoque          LoteEstoque[]
  romaneios             Romaneio[]
  ticketsBalanca        TicketBalanca[]
  classificacoes        Classificacao[]
  movimentacoesLote     MovimentacaoLote[]
  whatsappInstance      WhatsAppInstance?
  whatsappContacts      WhatsAppContact[]
  whatsappMessages      WhatsAppMessage[]
  // Originação & Fixação (Epic 1)
  contratosFixacao      ContratoFixacao[]
  fixacoes              Fixacao[]
  adiantamentos         Adiantamento[]
  barterInsumos         BarterInsumo[]
  planosVendas          PlanoVendas[]
  washouts              Washout[]
  // Hedge & Risco (Epic 4)
  posicoesHedge         PosicaoHedge[]
  ndfs                  NDF[]
  marcacoesMercado      MarcacaoMercado[]
  // Fiscal (Epic 3)
  configuracaoFiscal    ConfiguracaoFiscal?
  notasFiscais          NotaFiscal[]
  cartasCorrecao        CartaCorrecao[]
  spedExports           SpedExport[]
  // Compliance & Escala (Epic 5)
  aprovacaoWorkflows    AprovacaoWorkflow[]
  aprovacoes            Aprovacao[]
  centrosCusto          CentroCusto[]
  movimentosFinanceiros MovimentoFinanceiro[]
  talhoes               Talhao[]
  royalties             Royalty[]
  // S2 M10
  aceiteContratos       AceiteContrato[]
  pushSubscriptions     PushSubscription[]
  // S3 M3 — Assinatura digital + cláusulas + versionamento + marcos
  assinaturasDigitais   AssinaturaDigital[]
  clausulasContrato     ClausulaContrato[]
  contratoNotificacoes  ContratoNotificacao[]

  /// Moeda padrão da corretora (BRL é default; USD/ARS pra exportadoras)
  moedaPadrao String @default("BRL") // 'BRL' | 'USD' | 'ARS'

  onboardingCompletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  email       String
  role        String // 'owner' | 'admin' | 'member' | 'viewer'
  status      String    @default("active") // 'active' | 'invited' | 'suspended'
  inviteToken String?   @unique
  invitedAt   DateTime?
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@unique([workspaceId, email])
  @@index([workspaceId, status])
  @@index([userId])
}

model DadosEmpresa {
  id                String    @id @default(cuid())
  workspaceId       String    @unique
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  razaoSocial       String
  nomeFantasia      String?
  cnpj              String?
  inscricaoEstadual String?
  endereco          String?
  cidade            String?
  uf                String?
  cep               String?
  telefone          String?
  email             String?
  logoUrl           String?
  logoUploadedAt    DateTime?
  dadosBancarios    Json?
  certificadoPath   String?
  comissaoPadrao    Float?    @default(1.5)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Fornecedor {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tipo         String // 'transportadora' | 'armazem' | 'insumos' | 'certificadora' | 'outros'
  razaoSocial  String
  nomeFantasia String?
  cnpj         String?
  contato      String?
  telefone     String?
  email        String?
  endereco     String?
  cidade       String?
  uf           String?
  observacao   String?
  ativo        Boolean   @default(true)
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relações com Logística
  armazens                 Armazem[]
  transportadoraMotoristas Motorista[]       @relation("TransportadoraMotoristas")
  ordensTransporte         OrdemCarga[]      @relation("TransportadoraOrdens")
  whatsappContacts         WhatsAppContact[]
  // Originação (Epic 1) — fornecedores de insumos no barter
  barterInsumos            BarterInsumo[]
  // Compliance (Epic 5)
  royalties                Royalty[]

  @@index([workspaceId, tipo, ativo])
}

model ContratoTemplate {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  nome        String
  tipo        String // 'venda' | 'compra' | 'intermediacao' | 'outros'
  descricao   String?
  contentJson Json
  variaveis   Json?
  ativo       Boolean   @default(true)
  isDefault   Boolean   @default(false)
  // S3 M3 — versionamento de template
  versao      Int       @default(1)
  versoes     ContratoTemplateVersao[]
  // S3 M3 — cláusulas associadas a esse template (templates podem ter cláusulas padrão)
  clausulas   ClausulaContrato[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId, tipo, ativo])
}

// S3 M3 — Versões imutáveis de templates de contrato
model ContratoTemplateVersao {
  id         String           @id @default(cuid())
  templateId String
  template   ContratoTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  versao      Int
  contentJson Json
  variaveis   Json?

  createdAt DateTime @default(now())
  createdBy String?

  comentario String?

  @@unique([templateId, versao])
}

// ============================================
// ASSINATURAS (Stripe)
// ============================================

model Subscription {
  id                   String    @id @default(cuid())
  workspaceId          String    @unique
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String    @unique
  stripeCustomerId     String
  stripePriceId        String
  plan                 String // 'starter' | 'pro' | 'enterprise'
  status               String
  trialStart           DateTime?
  trialEnd             DateTime?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  canceledAt           DateTime?

  // Membros (cobrança extra)
  memberCount       Int     @default(1)
  extraSeatsCount   Int     @default(0)
  stripeBaseItemId  String?
  stripeSeatsItemId String?

  // Notificações idempotentes (cron de trial)
  notifTrialEndingAt  DateTime?
  notifTrialExpiredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([stripeCustomerId])
}

// ============================================
// CLASSIFICADOS (Marketplace)
// ============================================

model Classificado {
  id           String    @id @default(cuid())
  tipo         String // 'venda' | 'compra'
  grao         String // 'soja' | 'milho' | 'trigo' | 'sorgo'
  variedade    String?
  safra        String?
  volumeSc     Int
  precoSc      Decimal   @db.Decimal(10, 2)
  modal        String // 'FOB' | 'CIF'
  cidade       String
  uf           String
  deltaPct     Decimal?  @db.Decimal(5, 2)
  status       String    @default("ativo") // 'ativo' | 'pausado' | 'fechado'
  expiraEm     DateTime?
  autorId      String
  autor        User      @relation("ClassificadoAutor", fields: [autorId], references: [id], onDelete: Cascade)
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt

  @@index([grao, tipo, status])
  @@index([criadoEm])
  @@index([workspaceId])
}

// ============================================
// ALERTAS DE PREÇO
// ============================================

model AlertaPreco {
  id             String    @id @default(cuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  symbol         String // ex: 'ZS=F'
  graoLabel      String // ex: 'soja'
  operador       String // '>' | '<'
  preco          Decimal   @db.Decimal(10, 2)
  status         String    @default("ativo") // 'ativo' | 'disparado' | 'inativo'
  ultimoDisparo  DateTime?
  notifEnviadoEm DateTime? // último email de alerta enviado (idempotência cron)
  // QW6 — alertas de basis e câmbio além de preço puro
  tipo           String    @default("preco") // 'preco' | 'basis' | 'cambio'
  graoBase       String? // pra basis: 'soja' | 'milho' | 'trigo'
  criadoEm       DateTime  @default(now())

  @@index([workspaceId])
  @@index([status])
}

// ============================================
// CLIENTES (CRM)
// ============================================

model Cliente {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  nome        String    @db.VarChar(255)
  tipo        String    @default("ambos") // 'comprador' | 'vendedor' | 'ambos'
  email       String?   @db.VarChar(255)
  whatsapp    String?   @db.VarChar(20)
  cnpj        String?   @unique @db.VarChar(18)
  endereco    String?   @db.Text
  telefone    String?   @db.VarChar(20)
  ativo       Boolean   @default(true)
  // QW4 — cadastro PF/PJ + dados bancários + governança
  cpf                 String?  @unique @db.VarChar(14)
  tipoPessoa          String? // 'PF' | 'PJ'
  dadosBancarios      Json? // { banco, agencia, conta, tipo, pixChave }
  inscricaoEstadual   String?  @db.VarChar(30)
  porte               String? // 'ME' | 'EPP' | 'medio' | 'grande'
  origemCapital       String? // 'nacional' | 'estrangeiro'
  scoreRelacionamento Int? // 0-1000
  limiteCredito       Decimal? @db.Decimal(15, 2)
  /// QW5 — workflow de aprovação cadastral
  statusCadastral     String   @default("aprovado") // 'rascunho' | 'analise' | 'aprovado' | 'rejeitado'
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  propostas        Proposta[]
  contratos        Contrato[]
  boletos          Boleto[]
  contratosFuturos ContratoFuturo[]
  cargas           OrdemCarga[]      @relation("ClienteCargas")
  whatsappContacts WhatsAppContact[]
  // Originação (Epic 1) — produtor recebe adiantamentos
  adiantamentos    Adiantamento[]    @relation("ProdutorAdiantamentos")
  // Compliance (Epic 5)
  talhoes          Talhao[]
  // S2 M10
  pushSubscriptions PushSubscription[]

  @@index([email])
  @@index([cnpj])
  @@index([tipo])
  @@index([workspaceId])
}

// ============================================
// COTAÇÕES (CBOT via TradingView + Investing.com)
// ============================================

model Cotacao {
  id        String   @id @default(cuid())
  grao      String // 'soja' | 'milho' | 'trigo'
  preco     Decimal  @db.Decimal(10, 2) // cents/bushel — alias de close
  simbolo   String   @db.VarChar(10) // 'ZS' | 'ZC' | 'ZW'
  fonte     String   @default("TradingView") // TradingView | Investing.com
  dolarReal Decimal? @db.Decimal(10, 4) // Taxa USD/BRL nessa hora
  volume    Int? // volume negociado
  // QW7 — OHLC para análise técnica e candlestick
  open      Decimal? @db.Decimal(10, 2)
  high      Decimal? @db.Decimal(10, 2)
  low       Decimal? @db.Decimal(10, 2)
  close     Decimal? @db.Decimal(10, 2)
  data      DateTime @default(now())

  @@unique([grao, data])
  @@index([grao])
  @@index([data])
  @@index([simbolo])
}

model TaxaCambio {
  id      String   @id @default(cuid())
  origem  String   @default("USD")
  destino String   @default("BRL")
  taxa    Decimal  @db.Decimal(10, 4)
  fonte   String   @default("Investing.com")
  data    DateTime @default(now())

  @@unique([origem, destino, data])
  @@index([data])
}

// ============================================
// PROPOSTAS COMERCIAIS
// ============================================

model Proposta {
  id           String    @id @default(cuid())
  numero       String    @unique @db.VarChar(50)
  clienteId    String
  cliente      Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  tipo         String // 'venda' | 'compra'
  graos        Json
  valorTotal   Decimal   @db.Decimal(15, 2)
  status       String    @default("rascunho")
  descricao    String?   @db.Text
  observacoes  String?   @db.Text
  criadaEm     DateTime  @default(now())
  enviadaEm    DateTime?
  validadeEm   DateTime
  atualizadaEm DateTime  @updatedAt

  contratos Contrato[]

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@index([status])
  @@index([validadeEm])
  @@index([workspaceId])
}

// ============================================
// CONTRATOS
// ============================================

model Contrato {
  id               String    @id @default(cuid())
  numero           String    @unique @db.VarChar(50)
  proposIdFk       String
  proposta         Proposta  @relation(fields: [proposIdFk], references: [id], onDelete: Cascade)
  clienteId        String
  cliente          Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  dataInicio       DateTime
  dataFim          DateTime?
  pdfUrl           String?   @db.Text
  assinadoEm       DateTime?
  statusAssinatura String    @default("pendente")
  // QW8 — versionamento imutável do PDF (SHA-256)
  pdfHash          String?
  pdfHashedAt      DateTime?
  criadoEm         DateTime  @default(now())
  atualizadoEm     DateTime  @updatedAt

  boletos     Boleto[]
  ordensCarga OrdemCarga[]

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Modalidade — preço fixo, a fixar, misto, barter ou triangular
  modalidade String @default("fixo") // 'fixo' | 'a_fixar' | 'misto' | 'barter' | 'triangular'

  // Operação triangular: este contrato pode ser filho de outro (mesma origem)
  contratoOriginalId String?
  contratoOriginal   Contrato?  @relation("OperacaoTriangular", fields: [contratoOriginalId], references: [id], onDelete: SetNull)
  contratosFilhos    Contrato[] @relation("OperacaoTriangular")

  // S2 M10
  aceite                AceiteContrato?

  // S3 M3 — Snapshot imutável da versão de template usada na geração
  templateVersaoSnapshot Json?
  templateVersaoId       String?

  // S3 M3 — Forma + prazo de pagamento, local de entrega
  formaPagamento     String? // 'a_vista'|'parcelado'|'30_60_90'|'safra'|'misto'
  prazoPagamentoDias Int?
  localEntrega       String?

  // S3 M3 — Cláusulas customizáveis + assinatura digital + notificações
  clausulas         ClausulaContrato[]
  assinaturaDigital AssinaturaDigital?
  notificacoes      ContratoNotificacao[]

  // Originação (Epic 1)
  fixacao               ContratoFixacao?
  adiantamentos         Adiantamento[]
  barterInsumos         BarterInsumo[]
  washouts              Washout[]
  // Hedge (Epic 4): hedge financeiro vinculado a este contrato físico
  posicoesHedge         PosicaoHedge[]        @relation("HedgeContrato")
  // Fiscal (Epic 3)
  notasFiscais          NotaFiscal[]
  // Compliance (Epic 5)
  movimentosFinanceiros MovimentoFinanceiro[]
  royalties             Royalty[]
  /// Status próprio do contrato — quando há workflow de aprovação ativo
  statusAprovacao       String                @default("aprovado") // 'pendente_aprovacao' | 'aprovado' | 'rejeitado'

  @@index([clienteId])
  @@index([proposIdFk])
  @@index([assinadoEm])
  @@index([workspaceId])
  @@index([contratoOriginalId])
}

// ============================================
// BOLETOS DE COBRANÇA
// ============================================

model Boleto {
  id           String    @id @default(cuid())
  numero       String    @unique @db.VarChar(50)
  contratoIdFk String?
  contrato     Contrato? @relation(fields: [contratoIdFk], references: [id], onDelete: SetNull)
  clienteId    String
  cliente      Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  banco        String    @db.VarChar(20)
  valor        Decimal   @db.Decimal(15, 2)
  vencimento   DateTime
  status       String    @default("aberto")
  linkBoleto   String?   @db.Text
  braspagId    String?   @db.VarChar(100)
  confirmadoEm DateTime?
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Compliance (Epic 5)
  movimentosFinanceiros MovimentoFinanceiro[]

  @@index([clienteId])
  @@index([status])
  @@index([vencimento])
  @@index([braspagId])
  @@index([workspaceId])
}

// ============================================
// WEBHOOKS LOG (auditoria)
// ============================================

model WebhookLog {
  id         String   @id @default(cuid())
  tipo       String
  payload    Json
  status     String   @default("recebido")
  mensagem   String?  @db.Text
  codigoErro String?  @db.VarChar(50)
  ipOrigem   String?  @db.VarChar(50)
  timestamp  DateTime @default(now())
  criadoEm   DateTime @default(now())

  @@index([tipo])
  @@index([status])
  @@index([timestamp])
  @@index([criadoEm])
}

// ============================================
// EMAIL VERIFICATION & PASSWORD RESET
// ============================================

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  criadoEm  DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  criadoEm  DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// ============================================
// AUDITORIA DE AÇÕES
// ============================================

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  acao        String
  entidade    String
  entidadeId  String
  mudancas    Json?
  ipAddress   String?
  userAgent   String?
  /// QW3 — workspaceId opcional (eventos sem workspace: signup, login)
  workspaceId String?
  criadoEm    DateTime @default(now())

  @@index([userId])
  @@index([entidade])
  @@index([criadoEm])
  @@index([workspaceId])
}

// ============================================
// CACHE DE DADOS (Investing.com, etc)
// ============================================

model CacheData {
  id          String   @id @default(cuid())
  chave       String   @unique @db.VarChar(255)
  valor       Json
  expiracaoEm DateTime
  criadoEm    DateTime @default(now())

  @@index([expiracaoEm])
}

// ============================================
// PRICING CMS (planos dinâmicos editáveis)
// ============================================

model Plan {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  description     String?
  badge           String?
  highlight       Boolean  @default(false)
  priceCents      Int
  currency        String   @default("BRL")
  billingInterval String   @default("month")
  intervalCount   Int      @default(1)
  trialDays       Int      @default(10)
  ctaLabel        String   @default("Iniciar trial")
  ctaHref         String?
  tagline         String?
  sortOrder       Int      @default(0)
  active          Boolean  @default(true)
  stripeProductId String?  @unique
  stripePriceId   String?
  legacyPriceIds  String[] @default([])

  // Membros
  includedMembers        Int     @default(1)
  extraMemberPriceCents  Int     @default(15000)
  stripeExtraSeatPriceId String?

  features  PlanFeature[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([active, sortOrder])
}

model PlanFeature {
  id        String   @id @default(cuid())
  planId    String
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  label     String
  included  Boolean  @default(true)
  emphasis  Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([planId, sortOrder])
}

model PricingRevision {
  id        Int      @id @default(1)
  revision  Int      @default(1)
  updatedAt DateTime @updatedAt
}

// ============================================
// CONTRATOS FUTUROS (Book B3 próprio)
// ============================================

model ContratoFuturo {
  id           String    @id @default(cuid())
  /// LEGADO — será removido após backfill
  usuarioId    String?
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  grao         String // 'soja' | 'milho' | 'trigo' | 'sorgo'
  lado         String // 'compra' (bid) | 'venda' (ask)
  vencimento   DateTime  @db.Date
  precoSc      Decimal   @db.Decimal(10, 2)
  volumeSc     Int
  /// Codigo de vencimento estilo B3: K26 (mai/26), N26 (jul/26), X26 (nov/26)
  codigoVenc   String?   @db.VarChar(10)
  praca        String?   @db.VarChar(100)
  observacao   String?   @db.Text
  status       String    @default("ativo") // 'ativo' | 'executado' | 'cancelado'
  clienteId    String?
  cliente      Cliente?  @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt

  @@index([workspaceId, grao, status])
  @@index([vencimento])
}

// ============================================
// LOGÍSTICA — Armazéns, Motoristas, Ordens de Carga
// ============================================

model Armazem {
  id            String        @id @default(cuid())
  workspaceId   String
  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  nome          String
  tipo          String // 'silo' | 'granel' | 'horizontal' | 'misto'
  capacidadeSc  Int // capacidade em sacas 60kg
  endereco      String?
  cidade        String?
  uf            String?       @db.VarChar(2)
  cep           String?       @db.VarChar(10)
  contato       String?
  telefone      String?
  observacao    String?       @db.Text
  ativo         Boolean       @default(true)
  /// Próprio (galpão da empresa) ou terceirizado (Fornecedor)
  proprio       Boolean       @default(true)
  fornecedorId  String?
  fornecedor    Fornecedor?   @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)
  ordensOrigem  OrdemCarga[]  @relation("ArmazemOrigem")
  ordensDestino OrdemCarga[]  @relation("ArmazemDestino")
  // Operação Física (Epic 2)
  balancas      Balanca[]
  lotesEstoque  LoteEstoque[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([workspaceId, ativo])
  @@index([fornecedorId])
}

model Motorista {
  id               String          @id @default(cuid())
  workspaceId      String
  workspace        Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  nome             String
  cpf              String?         @db.VarChar(14)
  cnh              String?         @db.VarChar(20)
  cnhCategoria     String?         @db.VarChar(5)
  telefone         String?
  whatsapp         String?
  email            String?
  /// Veículo padrão
  placa            String?         @db.VarChar(10)
  veiculo          String?
  capacidadeSc     Int?
  /// Vinculado a uma transportadora (Fornecedor)
  transportadoraId String?
  transportadora   Fornecedor?     @relation("TransportadoraMotoristas", fields: [transportadoraId], references: [id], onDelete: SetNull)
  observacao       String?         @db.Text
  ativo            Boolean         @default(true)
  ordens           OrdemCarga[]
  // Operação Física (Epic 2)
  romaneios        Romaneio[]
  ticketsBalanca   TicketBalanca[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([workspaceId, ativo])
  @@index([transportadoraId])
}

model OrdemCarga {
  id               String      @id @default(cuid())
  numero           String      @unique
  workspaceId      String
  workspace        Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contratoId       String?
  contrato         Contrato?   @relation(fields: [contratoId], references: [id], onDelete: SetNull)
  clienteId        String?
  cliente          Cliente?    @relation("ClienteCargas", fields: [clienteId], references: [id], onDelete: SetNull)
  motoristaId      String?
  motorista        Motorista?  @relation(fields: [motoristaId], references: [id], onDelete: SetNull)
  transportadoraId String?
  transportadora   Fornecedor? @relation("TransportadoraOrdens", fields: [transportadoraId], references: [id], onDelete: SetNull)
  armazemOrigemId  String?
  armazemOrigem    Armazem?    @relation("ArmazemOrigem", fields: [armazemOrigemId], references: [id], onDelete: SetNull)
  armazemDestinoId String?
  armazemDestino   Armazem?    @relation("ArmazemDestino", fields: [armazemDestinoId], references: [id], onDelete: SetNull)
  grao             String // 'soja' | 'milho' | 'trigo' | 'sorgo'
  quantidadeSc     Int
  pesoToneladas    Decimal?    @db.Decimal(10, 2)
  /// Datas
  dataAgendada     DateTime
  dataCarregamento DateTime?
  dataDescarga     DateTime?
  /// CT-e
  ctEnumero        String?     @db.VarChar(50)
  ctEpdfUrl        String?     @db.Text
  ctEdataEmissao   DateTime?
  /// Status
  status           String      @default("agendada")
  observacao       String?     @db.Text
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([workspaceId, status])
  @@index([dataAgendada])
  @@index([motoristaId])
  @@index([transportadoraId])
  @@index([contratoId])
}

// ============================================
// OPERAÇÃO FÍSICA (Epic 2) — Safra, Lotes, Romaneios, Balança, Classificação
// ============================================

model Safra {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  nome    String // ex "2024/25"
  cultura String // 'soja' | 'milho' | 'trigo'
  inicio  DateTime
  fim     DateTime
  ativa   Boolean  @default(true)

  romaneios             Romaneio[]
  ticketsBalanca        TicketBalanca[]
  lotes                 LoteEstoque[]
  planosVendas          PlanoVendas[]
  // Compliance (Epic 5)
  movimentosFinanceiros MovimentoFinanceiro[]
  talhoes               Talhao[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, nome, cultura])
  @@index([workspaceId, ativa])
}

model TabelaClassificacao {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  cultura String
  nome    String

  umidadePadrao     Float
  umidadeMaxima     Float
  impurezaPadrao    Float
  impurezaMaxima    Float
  ardidosMaximo     Float
  quebradosMaximo   Float
  esverdeadosMaximo Float?
  pesoHectolitroMin Float?

  fatorDescontoUmidade   Float @default(1.0)
  fatorDescontoImpureza  Float @default(1.0)
  fatorDescontoArdidos   Float @default(2.0)
  fatorDescontoQuebrados Float @default(0.5)

  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, cultura, nome])
  @@index([workspaceId, cultura, ativo])
}

model Balanca {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  nome       String
  modelo     String?
  fabricante String?

  armazemId String?
  armazem   Armazem? @relation(fields: [armazemId], references: [id], onDelete: SetNull)

  capacidadeMaxKg    Int     @default(80000)
  precisaoKg         Int     @default(20)
  tipoIntegracao     String  @default("manual") // manual | serial | tcp | api
  enderecoIntegracao String?

  ativa     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticketsBalanca TicketBalanca[]

  @@index([workspaceId, ativa])
  @@index([armazemId])
}

model LoteEstoque {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  numero  String
  cultura String
  safraId String?
  safra   Safra?  @relation(fields: [safraId], references: [id], onDelete: SetNull)

  armazemId String
  armazem   Armazem @relation(fields: [armazemId], references: [id], onDelete: Restrict)

  qtdInicialSc Float
  qtdAtualSc   Float

  umidadeMedia  Float?
  impurezaMedia Float?

  status String @default("ativo") // ativo | consumido | transferido

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticketsBalanca TicketBalanca[]
  movimentacoes  MovimentacaoLote[]

  @@unique([workspaceId, numero])
  @@index([workspaceId, cultura, status])
  @@index([armazemId])
}

model Romaneio {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  numero String

  contratosIds String[]

  motoristaId String?
  motorista   Motorista? @relation(fields: [motoristaId], references: [id], onDelete: SetNull)

  origem  String
  destino String

  cultura String
  safraId String?
  safra   Safra?  @relation(fields: [safraId], references: [id], onDelete: SetNull)

  status String @default("rascunho") // rascunho | em_transito | recebido | cancelado

  dataSaida   DateTime?
  dataChegada DateTime?

  observacoes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticketsBalanca TicketBalanca[]
  notasFiscais   NotaFiscal[]

  @@unique([workspaceId, numero])
  @@index([workspaceId, status])
  @@index([motoristaId])
}

model TicketBalanca {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  numero String
  tipo   String // recepcao | expedicao | transferencia

  romaneioId String?
  romaneio   Romaneio? @relation(fields: [romaneioId], references: [id], onDelete: SetNull)

  balancaId String?
  balanca   Balanca? @relation(fields: [balancaId], references: [id], onDelete: SetNull)

  loteId String?
  lote   LoteEstoque? @relation(fields: [loteId], references: [id], onDelete: SetNull)

  pesoBrutoKg   Float
  taraKg        Float
  pesoLiquidoKg Float

  cultura String
  safraId String?
  safra   Safra?  @relation(fields: [safraId], references: [id], onDelete: SetNull)

  classificacaoId String?
  classificacao   Classificacao? @relation(fields: [classificacaoId], references: [id], onDelete: SetNull)

  placa       String?
  motoristaId String?
  motorista   Motorista? @relation(fields: [motoristaId], references: [id], onDelete: SetNull)

  fotoUrl     String?
  observacoes String? @db.Text

  status String @default("aberto") // aberto | classificado | finalizado

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, numero])
  @@index([workspaceId, status, tipo])
  @@index([romaneioId])
  @@index([loteId])
}

model Classificacao {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  cultura String

  umidade          Float
  impureza         Float
  ardidos          Float  @default(0)
  quebrados        Float  @default(0)
  esverdeados      Float?
  pesoHectolitroKg Float?

  tabelaId String?

  descontoUmidadePct   Float @default(0)
  descontoImpurezaPct  Float @default(0)
  descontoArdidosPct   Float @default(0)
  descontoQuebradosPct Float @default(0)
  descontoTotalPct     Float @default(0)

  pesoLiquidoFinalKg Float?

  classificadoPor String?
  observacoes     String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticketsBalanca TicketBalanca[]

  @@index([workspaceId, cultura])
}

model MovimentacaoLote {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  loteId String
  lote   LoteEstoque @relation(fields: [loteId], references: [id], onDelete: Cascade)

  tipo  String // entrada | saida | transferencia | quebra_tecnica | rebaixe
  qtdSc Float

  armazemDestinoId String?
  ticketBalancaId  String?
  contratoId       String?

  motivo String? @db.Text

  createdAt DateTime @default(now())

  @@index([workspaceId, loteId])
  @@index([tipo])
}

// ============================================
// WHATSAPP INSTÂNCIA (Evolution API por workspace)
// ============================================

model WhatsAppInstance {
  id          String    @id @default(cuid())
  workspaceId String    @unique
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  instanceName String  @unique
  evolutionId  String?
  status       String  @default("disconnected") // disconnected|connecting|connected|error

  phoneNumber   String?
  phoneJid      String?
  profileName   String?
  profilePicUrl String?

  connectedAt    DateTime?
  disconnectedAt DateTime?
  lastQrAt       DateTime?

  webhookSecret String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// ============================================
// WHATSAPP CONVERSAS (Contatos + Mensagens)
// ============================================

model WhatsAppContact {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  jid           String // ex: "5551999999999@s.whatsapp.net"
  phone         String? // só dígitos: "5551999999999"
  pushName      String? // nome que ele se identifica
  profilePicUrl String?

  // Vínculo opcional com Cliente/Fornecedor existente
  clienteId    String?
  cliente      Cliente?    @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  fornecedorId String?
  fornecedor   Fornecedor? @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)

  lastMessageAt DateTime?
  unreadCount   Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages WhatsAppMessage[]

  @@unique([workspaceId, jid])
  @@index([workspaceId, lastMessageAt])
  @@index([clienteId])
  @@index([fornecedorId])
}

model WhatsAppMessage {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  contactId String
  contact   WhatsAppContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  // Identificadores Evolution/WhatsApp
  messageId String // ID único da mensagem no WhatsApp (key.id)
  remoteJid String // JID do contact ou grupo
  fromMe    Boolean // true = enviada pela corretora, false = recebida

  // Conteúdo
  text         String? @db.Text
  mediaType    String? // image|video|audio|document|sticker|null
  mediaUrl     String?
  mediaCaption String?

  // Reply / quote
  replyToMessageId String?

  status String @default("delivered") // pending|sent|delivered|read|failed

  // Timestamps
  timestamp DateTime // timestamp do WhatsApp
  createdAt DateTime @default(now())

  @@unique([workspaceId, messageId]) // idempotência
  @@index([workspaceId, contactId, timestamp])
  @@index([workspaceId, timestamp])
}

// ============================================
// ORIGINAÇÃO & FIXAÇÃO (Epic 1)
// ============================================

/// Configuração de fixação de um contrato (apenas para modalidade "a_fixar" / "misto").
model ContratoFixacao {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  contratoId String   @unique
  contrato   Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  modalidade String // 'fixo' | 'a_fixar' | 'misto' | 'barter' | 'triangular'

  qtdTotalSc        Float
  qtdFixadaSc       Float @default(0)
  qtdRemanescenteSc Float

  fixacaoInicio DateTime?
  fixacaoFim    DateTime?

  gatilhoTipo    String? // 'preco_alvo' | 'manual' | 'data_limite'
  gatilhoPrecoSc Float?
  gatilhoCultura String? // 'soja' | 'milho' | 'trigo'

  statusFixacao String @default("pendente") // 'pendente' | 'parcial' | 'totalmente_fixado' | 'cancelado'

  observacoes String? @db.Text

  fixacoes Fixacao[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, statusFixacao])
}

/// Cada fixação parcial de preço sobre um ContratoFixacao.
model Fixacao {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  contratoFixacaoId String
  contratoFixacao   ContratoFixacao @relation(fields: [contratoFixacaoId], references: [id], onDelete: Cascade)

  qtdSc         Float
  precoSc       Float
  precoUSDSc    Float?
  cotacaoUSDBRL Float?
  premio        Float?
  base          Float?

  fixadoEm  DateTime @default(now())
  fixadoPor String?

  observacoes String? @db.Text
  pdfUrl      String?

  createdAt DateTime @default(now())

  @@index([contratoFixacaoId, fixadoEm])
  @@index([workspaceId])
}

/// Adiantamento ao produtor (cash ou insumo) — quitado pela entrega física.
model Adiantamento {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  numero String

  contratoId String
  contrato   Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  produtorId String
  produtor   Cliente @relation("ProdutorAdiantamentos", fields: [produtorId], references: [id], onDelete: Restrict)

  valor Decimal @db.Decimal(15, 2)

  tipo String // 'dinheiro' | 'insumo' | 'misto'

  dataAdiantamento DateTime  @default(now())
  dataPrevistaQuit DateTime?

  qtdAbatidaSc  Float @default(0)
  qtdEsperadaSc Float

  status String @default("aberto") // 'aberto' | 'parcial' | 'quitado' | 'inadimplente'

  observacoes String? @db.Text

  itensInsumo BarterInsumo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, numero])
  @@index([workspaceId, status])
  @@index([produtorId])
  @@index([contratoId])
}

/// Insumo entregue ao produtor (barter) — convertido em sacas equivalentes.
model BarterInsumo {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  adiantamentoId String?
  adiantamento   Adiantamento? @relation(fields: [adiantamentoId], references: [id], onDelete: SetNull)

  contratoId String
  contrato   Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  descricao    String
  fornecedorId String?
  fornecedor   Fornecedor? @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)

  quantidade Float
  unidade    String // 'kg' | 'l' | 'sc' | 'un'
  precoUnit  Decimal @db.Decimal(10, 2)
  valorTotal Decimal @db.Decimal(15, 2)

  precoFixadoSc        Float
  qtdGraoEquivalenteSc Float

  status String @default("pendente") // 'pendente' | 'entregue' | 'recebido_grao' | 'cancelado'

  dataEntregaInsumo DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, status])
  @@index([contratoId])
  @@index([adiantamentoId])
  @@index([fornecedorId])
}

/// Plano de vendas / forecast por safra+cultura.
model PlanoVendas {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  safraId String?
  safra   Safra?  @relation(fields: [safraId], references: [id], onDelete: SetNull)

  cultura String

  qtdPrevistaSc   Float
  qtdContratadaSc Float @default(0)
  qtdFixadaSc     Float @default(0)
  qtdEntregueSc   Float @default(0)

  precoMedioPrevistoSc Float?

  observacoes String? @db.Text

  status String @default("ativo") // 'ativo' | 'concluido' | 'cancelado'

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, cultura, safraId])
  @@index([workspaceId, status])
}

/// Washout — desfazimento de contrato com motivo e custo associado.
model Washout {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  contratoId String
  contrato   Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  motivo          String // 'cliente_desistiu' | 'forcas_maior' | 'preco_inviavel' | 'outro'
  motivoDescricao String? @db.Text

  custoWashout  Decimal @default(0) @db.Decimal(15, 2)
  custoQuemPaga String? // 'comprador' | 'vendedor' | 'corretora'

  qtdAfetadaSc Float

  aprovadoPor String?

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([contratoId])
}

// ============================================
// EPIC 4 — HEDGE & RISCO
// (Long/Short, NDF, Marcação a Mercado, Multi-moeda)
// ============================================

/// Posição de hedge financeiro (Long ou Short).
/// IMPORTANTE: distinta de `ContratoFuturo` — ContratoFuturo modela negócio
/// comercial (cliente compra/vende lote físico futuro). PosicaoHedge é operação
/// financeira pura na bolsa (CBOT/B3) usada como instrumento de proteção.
model PosicaoHedge {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  numero String // ex 'HDG-2024-001'
  tipo   String // 'long' | 'short'

  cultura        String? // 'soja' | 'milho' | 'trigo' (null se hedge cambial puro)
  contratoFuturo String // 'ZS' | 'ZC' | 'ZW' (CBOT) ou 'SBM' (B3)
  vencimento     DateTime // mês de vencimento (1º dia)

  qtdContratos     Float // num contratos futuros (1 contrato CBOT soja = 5000 bushels = 136 t)
  qtdEquivalenteSc Float // qtd em sacas equivalente (calculada)

  // Preços
  precoEntradaUsdBu Decimal? @db.Decimal(10, 4) // CBOT: USD/bushel
  precoEntradaBrlSc Decimal? @db.Decimal(10, 2) // BR: R$/sc

  // Câmbio na entrada (importante pra P&L)
  cambioEntradaUsdBrl Decimal? @db.Decimal(10, 4)

  // Margem inicial / depositada
  margemDepositadaUSD Decimal? @db.Decimal(15, 2)
  margemDepositadaBRL Decimal? @db.Decimal(15, 2)

  // Custos
  corretagemUSD Decimal @default(0) @db.Decimal(10, 2)

  // Vínculos
  contratoOrigemId String?
  contratoOrigem   Contrato? @relation("HedgeContrato", fields: [contratoOrigemId], references: [id], onDelete: SetNull)

  status String @default("aberta") // 'aberta' | 'fechada' | 'rolada' | 'liquidada'

  abertoEm  DateTime  @default(now())
  fechadoEm DateTime?

  // Quando fechado
  precoSaidaUsdBu   Decimal? @db.Decimal(10, 4)
  precoSaidaBrlSc   Decimal? @db.Decimal(10, 2)
  cambioSaidaUsdBrl Decimal? @db.Decimal(10, 4)
  pnlFinalUSD       Decimal? @db.Decimal(15, 2)
  pnlFinalBRL       Decimal? @db.Decimal(15, 2)

  observacoes String? @db.Text

  marcacoes MarcacaoMercado[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, numero])
  @@index([workspaceId, status])
  @@index([cultura, vencimento])
  @@index([contratoOrigemId])
}

/// NDF — Non-Deliverable Forward (moeda ou commodity).
model NDF {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  numero String
  tipo   String // 'moeda' | 'commodity'

  contraparteNome String
  contraparteCnpj String?

  direcao   String // 'compra' | 'venda'
  ativoTipo String // 'USDBRL' | 'EURBRL' | 'ZS' | 'ZC' | 'ZW' ...

  notional Decimal @db.Decimal(15, 2) // valor de referência
  strike   Decimal @db.Decimal(10, 4) // taxa contratada

  dataAbertura   DateTime @default(now())
  dataVencimento DateTime

  status String @default("aberta") // 'aberta' | 'liquidada' | 'cancelada'

  precoLiquidacao Decimal? @db.Decimal(10, 4)
  resultadoBRL    Decimal? @db.Decimal(15, 2)

  observacoes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, numero])
  @@index([workspaceId, status])
  @@index([dataVencimento])
}

/// Marcação a Mercado — snapshot diário das posições abertas.
model MarcacaoMercado {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  posicaoHedgeId String
  posicaoHedge   PosicaoHedge @relation(fields: [posicaoHedgeId], references: [id], onDelete: Cascade)

  data DateTime // dia da marcação

  precoMercadoUsdBu Decimal? @db.Decimal(10, 4)
  precoMercadoBrlSc Decimal? @db.Decimal(10, 2)
  cambioUsdBrl      Decimal? @db.Decimal(10, 4)

  pnlUnrealizedUSD Decimal @db.Decimal(15, 2)
  pnlUnrealizedBRL Decimal @db.Decimal(15, 2)

  variacaoDiaUSD Decimal? @db.Decimal(15, 2)
  variacaoDiaBRL Decimal? @db.Decimal(15, 2)

  createdAt DateTime @default(now())

  @@unique([posicaoHedgeId, data])
  @@index([workspaceId, data])
}

// ============================================
// EPIC 3 — FISCAL (NF-e + SPED)
// ============================================

model ConfiguracaoFiscal {
  id          String    @id @default(cuid())
  workspaceId String    @unique
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Dados emissor
  cnpjEmissor        String
  inscricaoEstadual  String?
  inscricaoMunicipal String?
  regimeTributario   String // 'simples_nacional' | 'lucro_presumido' | 'lucro_real' | 'mei'
  cnae               String?

  // Provider config
  providerNome      String  @default("mock") // 'mock' | 'nfeio' | 'enotas' | 'webmania' | 'tecnospeed'
  providerCompanyId String?
  ambiente          String  @default("homologacao") // 'homologacao' | 'producao'

  // Certificado A1 (Supabase Storage URL)
  certificadoUrl        String?
  certificadoVencimento DateTime?
  certificadoAlias      String?

  // Padrões NF-e
  serieNFe             Int  @default(1)
  proximoNumeroNFe     Int  @default(1)
  serieNFeContingencia Int?

  // Padrões fiscais
  cfopCompraProdutorPF   String @default("1102")
  cfopCompraProdutorPJ   String @default("1102")
  cfopVendaInterestadual String @default("6101")
  cfopVendaIntraestadual String @default("5101")

  // FUNRURAL
  funruralAplicar  Boolean @default(true)
  funruralAliquota Float   @default(1.3)

  // SPED
  cnaeSped String?

  ativo Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notasFiscais NotaFiscal[]
}

model NotaFiscal {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  configFiscalId String
  configFiscal   ConfiguracaoFiscal @relation(fields: [configFiscalId], references: [id], onDelete: Cascade)

  // Tipo / modelo
  tipo   String // 'entrada' | 'saida' | 'devolucao' | 'complementar' | 'triangular'
  modelo String @default("55") // 55 = NF-e, 65 = NFC-e

  // Numeração
  serie     Int
  numero    Int
  chave     String? @unique
  protocolo String?

  // Status SEFAZ
  status         String  @default("rascunho")
  // 'rascunho' | 'enviada' | 'autorizada' | 'rejeitada' | 'cancelada' | 'inutilizada' | 'denegada'
  motivoRejeicao String? @db.Text

  // Datas
  dataEmissao      DateTime  @default(now())
  dataAutorizacao  DateTime?
  dataCancelamento DateTime?

  // Vínculos
  contratoId  String?
  contrato    Contrato? @relation(fields: [contratoId], references: [id], onDelete: SetNull)
  romaneioId  String?
  romaneioRel Romaneio? @relation(fields: [romaneioId], references: [id], onDelete: SetNull)

  // Emitente snapshot
  emitenteCnpj String
  emitenteNome String
  emitenteUF   String

  // Destinatário snapshot
  destinatarioDoc  String
  destinatarioNome String
  destinatarioUF   String
  destinatarioIE   String?

  // Itens (JSON)
  itens Json

  // Totais
  valorProdutos Decimal @db.Decimal(15, 2)
  valorICMS     Decimal @default(0) @db.Decimal(15, 2)
  valorPIS      Decimal @default(0) @db.Decimal(15, 2)
  valorCOFINS   Decimal @default(0) @db.Decimal(15, 2)
  valorFUNRURAL Decimal @default(0) @db.Decimal(15, 2)
  valorFrete    Decimal @default(0) @db.Decimal(15, 2)
  valorOutros   Decimal @default(0) @db.Decimal(15, 2)
  valorTotal    Decimal @db.Decimal(15, 2)

  cfopPrincipal     String
  naturezaOperacao  String
  finalidadeEmissao String @default("1")

  intermunicipal Boolean @default(false)
  interestadual  Boolean @default(false)

  // Triangular
  notaPaiId   String?
  notaPaiRel  NotaFiscal?  @relation("NotaTriangular", fields: [notaPaiId], references: [id], onDelete: SetNull)
  notasFilhas NotaFiscal[] @relation("NotaTriangular")

  // Diferimento ICMS
  diferimentoICMS Boolean @default(false)

  // Provider
  providerResponse Json?
  providerNFeId    String?

  // PDFs / XMLs
  xmlUrl   String?
  danfeUrl String?

  observacoes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cartasCorrecao CartaCorrecao[]

  @@unique([workspaceId, serie, numero])
  @@index([workspaceId, status])
  @@index([dataEmissao])
  @@index([chave])
  @@index([contratoId])
}

model CartaCorrecao {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  notaFiscalId String
  notaFiscal   NotaFiscal @relation(fields: [notaFiscalId], references: [id], onDelete: Cascade)

  sequencia Int
  texto     String @db.Text

  status    String  @default("rascunho") // 'rascunho' | 'aceita' | 'rejeitada'
  protocolo String?
  motivo    String? @db.Text

  dataAceite DateTime?

  createdAt DateTime @default(now())

  @@unique([notaFiscalId, sequencia])
}

model SpedExport {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  tipo        String // 'fiscal' | 'contribuicoes'
  competencia String // 'YYYYMM'

  arquivoUrl     String?
  totalRegistros Int     @default(0)

  status  String  @default("processando") // 'processando' | 'pronto' | 'erro'
  erroMsg String? @db.Text

  hashArquivo String?

  geradoEm DateTime?

  createdAt DateTime @default(now())

  @@unique([workspaceId, tipo, competencia])
  @@index([workspaceId])
}

// ============================================
// COMPLIANCE & ESCALA (Epic 5) — Aprovação multi-nível, DRE, Conciliação, Talhões, Royalties
// ============================================

/// Workflow de aprovação multi-nível por entidade.
model AprovacaoWorkflow {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  nome      String
  descricao String? @db.Text

  /// Entidade que dispara workflow: 'contrato' | 'fixacao' | 'washout' | 'adiantamento' | 'nf_emissao'
  entidade String
  /// JSON com condições, ex: { "valorMinimo": 500000 } ou { "qtdMinimaSc": 5000 }
  condicao Json
  /// Array ordenado de etapas: [{ ordem, role, nome }]
  etapas   Json

  slaHoras Int     @default(48)
  ativo    Boolean @default(true)

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  aprovacoes Aprovacao[]

  @@index([workspaceId, entidade, ativo])
}

/// Instância de aprovação em curso ou finalizada.
model Aprovacao {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  workflowId String
  workflow   AprovacaoWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  entidadeTipo String
  entidadeId   String

  snapshot Json

  etapaAtual  Int @default(1)
  totalEtapas Int

  /// 'pendente' | 'aprovada' | 'rejeitada' | 'cancelada' | 'expirada'
  status String @default("pendente")

  solicitanteId String
  solicitante   User   @relation("AprovacaoSolicitante", fields: [solicitanteId], references: [id], onDelete: Restrict)

  prazoEtapaAtual DateTime

  observacoes String?            @db.Text
  decisoes    AprovacaoDecisao[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, status, etapaAtual])
  @@index([entidadeTipo, entidadeId])
}

model AprovacaoDecisao {
  id String @id @default(cuid())

  aprovacaoId String
  aprovacao   Aprovacao @relation(fields: [aprovacaoId], references: [id], onDelete: Cascade)

  etapa       Int
  aprovadorId String
  aprovador   User   @relation(fields: [aprovadorId], references: [id], onDelete: Restrict)

  /// 'aprovado' | 'rejeitado'
  decisao String
  motivo  String? @db.Text

  decididoEm DateTime @default(now())

  @@unique([aprovacaoId, etapa])
}

/// Centro de custo hierárquico (DRE / contabilidade gerencial).
model CentroCusto {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  codigo    String
  nome      String
  descricao String? @db.Text

  paiId  String?
  pai    CentroCusto?  @relation("CentroCustoHierarquia", fields: [paiId], references: [id], onDelete: SetNull)
  filhos CentroCusto[] @relation("CentroCustoHierarquia")

  ativo Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movimentos MovimentoFinanceiro[]

  @@unique([workspaceId, codigo])
  @@index([workspaceId, ativo])
}

/// Movimento financeiro — base para DRE e conciliação bancária.
model MovimentoFinanceiro {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  data     DateTime
  /// 'receita' | 'despesa' | 'transferencia'
  tipo     String
  /// 'comissao' | 'frete' | 'corretagem' | 'imposto' | 'salario' | 'outros'
  natureza String

  valor     Decimal @db.Decimal(15, 2)
  descricao String

  centroCustoId String?
  centroCusto   CentroCusto? @relation(fields: [centroCustoId], references: [id], onDelete: SetNull)

  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id], onDelete: SetNull)

  boletoId String?
  boleto   Boleto? @relation(fields: [boletoId], references: [id], onDelete: SetNull)

  safraId String?
  safra   Safra?  @relation(fields: [safraId], references: [id], onDelete: SetNull)

  cultura String?

  conciliado   Boolean   @default(false)
  conciliadoEm DateTime?
  ofxLineHash  String?   @unique

  observacoes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, data])
  @@index([workspaceId, tipo, natureza])
  @@index([centroCustoId])
  @@index([safraId])
}

/// Talhão / Gleba do produtor.
model Talhao {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  produtorId String
  produtor   Cliente @relation(fields: [produtorId], references: [id], onDelete: Cascade)

  nome String
  area Float

  cultura String?
  safraId String?
  safra   Safra?  @relation(fields: [safraId], references: [id], onDelete: SetNull)

  produtividadeEstimadaSc Float?
  produtividadeRealSc     Float?

  latitude  Float?
  longitude Float?
  municipio String?
  uf        String?

  observacoes String?  @db.Text
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([workspaceId, produtorId, nome])
  @@index([workspaceId, ativo])
  @@index([safraId])
}

/// Royalty de sementes/cultivar (apurado por contrato).
model Royalty {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  contratoId String
  contrato   Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  detentorId String
  detentor   Fornecedor @relation(fields: [detentorId], references: [id], onDelete: Restrict)

  cultivar   String
  qtdSc      Float
  valorPorSc Decimal @db.Decimal(10, 4)
  valorTotal Decimal @db.Decimal(15, 2)

  /// 'apurado' | 'pago' | 'contestado'
  status String @default("apurado")

  pagoEm DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, status])
  @@index([contratoId])
}

// ============================================
// S2 M10 — 2FA, Aceite Digital, Web Push
// ============================================

model Pending2FA {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AceiteContrato {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  contratoId String   @unique
  contrato   Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  tokenHash String @unique

  aceitanteNome    String?
  aceitanteCpfCnpj String?

  aceitoEm        DateTime?
  ipAceite        String?
  userAgentAceite String?

  geoLat Float?
  geoLng Float?

  pdfHashAceito String?

  status String @default("pendente") // 'pendente' | 'aceito' | 'recusado' | 'expirado'

  enviadoEm DateTime @default(now())
  expiraEm  DateTime

  observacoesRecusa String? @db.Text

  @@index([workspaceId, status])
  @@index([tokenHash])
}

model PushSubscription {
  id          String     @id @default(cuid())
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  endpoint String @unique
  p256dh   String
  auth     String

  ativo       Boolean   @default(true)
  ultimoEnvio DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([clienteId])
  @@index([workspaceId])
}

// ============================================
// S3 M3 — ASSINATURA DIGITAL + CLÁUSULAS + NOTIFICAÇÕES
// ============================================

model AssinaturaDigital {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  contratoId String   @unique
  contrato   Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  providerNome  String // 'mock' | 'zapsign' | 'clicksign' | 'd4sign'
  providerDocId String @unique

  authMode String // 'simple' | 'icp_brasil' | 'sms' | 'email_token'

  status String @default("pendente") // 'pendente'|'parcial'|'assinado'|'recusado'|'expirado'|'cancelado'

  enviadoEm    DateTime  @default(now())
  finalizadoEm DateTime?
  expiraEm     DateTime?

  signatarios Json // [{name, cpfCnpj, email, signedAt, refusedAt, ip, ...}]

  pdfOriginalHash String?
  pdfAssinadoUrl  String?
  pdfAssinadoHash String?

  carimboTempo Json? // RFC 3161 timestamp se disponível

  webhookSecret String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, status])
}

model ClausulaContrato {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  templateId String?
  template   ContratoTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  ordem  Int
  tipo   String // 'multa'|'arbitragem'|'foro'|'forca_maior'|'pagamento'|'entrega'|'outras'
  titulo String
  texto  String @db.Text

  obrigatoria Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contratoId])
  @@index([templateId])
}

model ContratoNotificacao {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  contratoId String
  contrato   Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  marco     String // '30d'|'15d'|'7d'|'1d'|'vencido'
  enviadoEm DateTime @default(now())

  @@unique([contratoId, marco])
  @@index([workspaceId])
}

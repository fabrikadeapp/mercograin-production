// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// AUTENTICAÇÃO & USUÁRIOS
// ============================================

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  senha            String // Hash bcrypt
  nome             String
  role             String   @default("user") // 'admin' | 'user' | 'viewer'
  emailVerificado  Boolean  @default(false)
  stripeCustomerId String?  @unique
  criadoEm         DateTime @default(now())
  atualizadoEm     DateTime @updatedAt

  // 2FA TOTP (S2 M10)
  totpSecret     String?
  totpEnabled    Boolean   @default(false)
  totpVerifiedAt DateTime?
  recoveryCodes  String[]  @default([])

  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  classificados           Classificado[]           @relation("ClassificadoAutor")
  pushSubscriptions       PushSubscription[]
  pending2FA              Pending2FA[]

  // Workspaces
  workspacesOwned      Workspace[]       @relation("WorkspaceOwner")
  workspaceMemberships WorkspaceMember[]

  // Compliance (Epic 5)
  aprovacoesSolicitadas Aprovacao[]        @relation("AprovacaoSolicitante")
  aprovacaoDecisoes     AprovacaoDecisao[]

  // S6 M5 Risco — perfis de corretor
  corretorPerfis Corretor[]

  // S10 M2 Mesa profissional — ofertas + cenários da calculadora
  ofertas             Oferta[]             @relation("OfertaProprietario")
  cenariosCalculadora CenarioCalculadora[]

  @@index([email])
}

// ============================================
// WORKSPACES (Multi-tenancy v2)
// ============================================

model Workspace {
  id      String @id @default(cuid())
  name    String
  slug    String @unique
  ownerId String
  owner   User   @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  members      WorkspaceMember[]
  empresa      DadosEmpresa?
  subscription Subscription?

  // Relações migradas de usuarioId → workspaceId
  clientes               Cliente[]
  propostas              Proposta[]
  contratos              Contrato[]
  boletos                Boleto[]
  classificados          Classificado[]
  alertasPreco           AlertaPreco[]
  contratosFuturos       ContratoFuturo[]
  fornecedores           Fornecedor[]
  templatesContrato      ContratoTemplate[]
  armazens               Armazem[]
  motoristas             Motorista[]
  ordensCarga            OrdemCarga[]
  // Operação Física (Epic 2)
  safras                 Safra[]
  tabelasClassificacao   TabelaClassificacao[]
  balancas               Balanca[]
  lotesEstoque           LoteEstoque[]
  romaneios              Romaneio[]
  ticketsBalanca         TicketBalanca[]
  classificacoes         Classificacao[]
  movimentacoesLote      MovimentacaoLote[]
  whatsappInstance       WhatsAppInstance?
  whatsappContacts       WhatsAppContact[]
  whatsappMessages       WhatsAppMessage[]
  // Originação & Fixação (Epic 1)
  contratosFixacao       ContratoFixacao[]
  fixacoes               Fixacao[]
  adiantamentos          Adiantamento[]
  barterInsumos          BarterInsumo[]
  planosVendas           PlanoVendas[]
  washouts               Washout[]
  // Hedge & Risco (Epic 4)
  posicoesHedge          PosicaoHedge[]
  ndfs                   NDF[]
  marcacoesMercado       MarcacaoMercado[]
  // Fiscal (Epic 3)
  configuracaoFiscal     ConfiguracaoFiscal?
  notasFiscais           NotaFiscal[]
  cartasCorrecao         CartaCorrecao[]
  spedExports            SpedExport[]
  // S9 M7 — Guias fiscais (DARF/GNRE/GARE)
  guias                  Guia[]
  // Compliance & Escala (Epic 5)
  aprovacaoWorkflows     AprovacaoWorkflow[]
  aprovacoes             Aprovacao[]
  centrosCusto           CentroCusto[]
  movimentosFinanceiros  MovimentoFinanceiro[]
  talhoes                Talhao[]
  royalties              Royalty[]
  // S2 M10
  aceiteContratos        AceiteContrato[]
  pushSubscriptions      PushSubscription[]
  // S3 M3 — Assinatura digital + cláusulas + versionamento + marcos
  assinaturasDigitais    AssinaturaDigital[]
  clausulasContrato      ClausulaContrato[]
  contratoNotificacoes   ContratoNotificacao[]
  // S4 M1 — Compliance KYC + propriedades rurais
  propriedadesRurais     PropriedadeRural[]
  // S5 M9 — EUDR: cadeia de custódia + DDS
  talhaoLotes            TalhaoLote[]
  duediligenceStatements DueDiligenceStatement[]
  // S6 M5 — Risco profissional
  mesas                  Mesa[]
  corretores             Corretor[]
  limitesRisco           LimiteRisco[]
  limitesBreach          LimiteBreach[]
  // S8 M6 — Comissão hierárquica
  comissaoRegras         ComissaoRegra[]
  comissoesApuradas      ComissaoApurada[]
  // S10 M2 — Mesa profissional
  ofertas                Oferta[]
  cenariosCalculadora    CenarioCalculadora[]
  // S12 M10 — Portal produtor
  produtorAccessos       ProdutorAccess[]
  documentosProdutor     DocumentoProdutor[]
  mensagensProdutor      MensagemProdutor[]
  // BH Grain (Lote 2) — Inbox unificado, metas, alertas, regras, health
  conversations          Conversation[]
  conversationMessages   ConversationMessage[]
  metasComerciais        MetaComercial[]
  commodityMarginRules   CommodityMarginRule[]
  commercialAlerts       CommercialAlert[]
  commercialRules        CommercialRule[]
  integrationHealth      IntegrationHealth[]
  // BH Grain (Lote 15) — credenciais de integração por canal (1:N — possível múltiplas contas no futuro, mas uniqueness por canal)
  integrationCredentials IntegrationCredential[]

  /// Moeda padrão da corretora (BRL é default; USD/ARS pra exportadoras)
  moedaPadrao String @default("BRL") // 'BRL' | 'USD' | 'ARS'

  /// AI provider — 'managed' = usa chave da plataforma (faturado via licença)
  /// 'byok' = cliente traz própria chave OpenAI (mais barato, ele paga consumo).
  /// Default 'managed' — super-admin libera 'byok' para planos Enterprise.
  aiMode String @default("managed")

  /// Chave OpenAI do cliente quando aiMode='byok' — criptografada AES-256-GCM
  aiKeyEncrypted String? @db.Text
  aiKeyIv        String?
  aiKeyTag       String?

  /// Modelo OpenAI preferido (default gpt-4o-mini)
  aiModel String @default("gpt-4o-mini")

  /// Lista de IDs de commodities visíveis no widget do dashboard.
  /// null/vazio = usa DEFAULT_DASHBOARD_IDS (lib/commodities/catalog.ts).
  dashboardSymbols Json?

  onboardingCompletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  email       String
  role        String // 'owner' | 'admin' | 'member' | 'viewer'
  status      String    @default("active") // 'active' | 'invited' | 'suspended'
  /// BH Grain — perfil comercial granular (opcional, ortogonal ao role).
  /// 'gestor' | 'trader' | 'vendedor' | 'financeiro' | 'operador' | 'leitura'
  /// null = sem perfil específico; permissões caem para role base.
  commercialRole String?
  inviteToken String?   @unique
  invitedAt   DateTime?
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@unique([workspaceId, email])
  @@index([workspaceId, status])
  @@index([userId])
}

model DadosEmpresa {
  id                String    @id @default(cuid())
  workspaceId       String    @unique
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  razaoSocial       String
  nomeFantasia      String?
  cnpj              String?
  inscricaoEstadual String?
  endereco          String?
  cidade            String?
  uf                String?
  cep               String?
  telefone          String?
  email             String?
  logoUrl           String?
  logoUploadedAt    DateTime?
  dadosBancarios    Json?
  certificadoPath   String?
  comissaoPadrao    Float?    @default(1.5)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Fornecedor {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tipo         String // 'transportadora' | 'armazem' | 'insumos' | 'certificadora' | 'outros'
  razaoSocial  String
  nomeFantasia String?
  cnpj         String?
  contato      String?
  telefone     String?
  email        String?
  endereco     String?
  cidade       String?
  uf           String?
  observacao   String?
  ativo        Boolean   @default(true)
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relações com Logística
  armazens                 Armazem[]
  transportadoraMotoristas Motorista[]       @relation("TransportadoraMotoristas")
  ordensTransporte         OrdemCarga[]      @relation("TransportadoraOrdens")
  whatsappContacts         WhatsAppContact[]
  // Originação (Epic 1) — fornecedores de insumos no barter
  barterInsumos            BarterInsumo[]
  // Compliance (Epic 5)
  royalties                Royalty[]

  @@index([workspaceId, tipo, ativo])
}

model ContratoTemplate {
  id          String                   @id @default(cuid())
  workspaceId String
  workspace   Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  nome        String
  tipo        String // 'venda' | 'compra' | 'intermediacao' | 'outros'
  descricao   String?
  contentJson Json
  variaveis   Json?
  ativo       Boolean                  @default(true)
  isDefault   Boolean                  @default(false)
  // S3 M3 — versionamento de template
  versao      Int                      @default(1)
  versoes     ContratoTemplateVersao[]
  // S3 M3 — cláusulas associadas a esse template (templates podem ter cláusulas padrão)
  clausulas   ClausulaContrato[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([workspaceId, tipo, ativo])
}

// S3 M3 — Versões imutáveis de templates de contrato
model ContratoTemplateVersao {
  id         String           @id @default(cuid())
  templateId String
  template   ContratoTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  versao      Int
  contentJson Json
  variaveis   Json?

  createdAt DateTime @default(now())
  createdBy String?

  comentario String?

  @@unique([templateId, versao])
}

// ============================================
// ASSINATURAS (Stripe)
// ============================================

model Subscription {
  id                   String    @id @default(cuid())
  workspaceId          String    @unique
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String    @unique
  stripeCustomerId     String
  stripePriceId        String
  plan                 String // 'starter' | 'pro' | 'enterprise'
  status               String
  trialStart           DateTime?
  trialEnd             DateTime?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  canceledAt           DateTime?

  // Membros (cobrança extra)
  memberCount       Int     @default(1)
  extraSeatsCount   Int     @default(0)
  stripeBaseItemId  String?
  stripeSeatsItemId String?

  // Notificações idempotentes (cron de trial)
  notifTrialEndingAt  DateTime?
  notifTrialExpiredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([stripeCustomerId])
}

// ============================================
// CLASSIFICADOS (Marketplace)
// ============================================

model Classificado {
  id           String    @id @default(cuid())
  tipo         String // 'venda' | 'compra'
  grao         String // 'soja' | 'milho' | 'trigo' | 'sorgo'
  variedade    String?
  safra        String?
  volumeSc     Int
  precoSc      Decimal   @db.Decimal(10, 2)
  modal        String // 'FOB' | 'CIF'
  cidade       String
  uf           String
  deltaPct     Decimal?  @db.Decimal(5, 2)
  status       String    @default("ativo") // 'ativo' | 'pausado' | 'fechado'
  expiraEm     DateTime?
  autorId      String
  autor        User      @relation("ClassificadoAutor", fields: [autorId], references: [id], onDelete: Cascade)
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt

  @@index([grao, tipo, status])
  @@index([criadoEm])
  @@index([workspaceId])
}

// ============================================
// ALERTAS DE PREÇO
// ============================================

model AlertaPreco {
  id             String    @id @default(cuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  symbol         String // ex: 'ZS=F'
  graoLabel      String // ex: 'soja'
  operador       String // '>' | '<'
  preco          Decimal   @db.Decimal(10, 2)
  status         String    @default("ativo") // 'ativo' | 'disparado' | 'inativo'
  ultimoDisparo  DateTime?
  notifEnviadoEm DateTime? // último email de alerta enviado (idempotência cron)
  // QW6 — alertas de basis e câmbio além de preço puro
  tipo           String    @default("preco") // 'preco' | 'basis' | 'cambio'
  graoBase       String? // pra basis: 'soja' | 'milho' | 'trigo'
  criadoEm       DateTime  @default(now())

  @@index([workspaceId])
  @@index([status])
}

// ============================================
// CLIENTES (CRM)
// ============================================

model Cliente {
  id                  String    @id @default(cuid())
  workspaceId         String
  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  nome                String    @db.VarChar(255)
  tipo                String    @default("ambos") // 'comprador' | 'vendedor' | 'ambos'
  email               String?   @db.VarChar(255)
  whatsapp            String?   @db.VarChar(20)
  cnpj                String?   @unique @db.VarChar(18)
  endereco            String?   @db.Text
  telefone            String?   @db.VarChar(20)
  ativo               Boolean   @default(true)
  // QW4 — cadastro PF/PJ + dados bancários + governança
  cpf                 String?   @unique @db.VarChar(14)
  tipoPessoa          String? // 'PF' | 'PJ'
  dadosBancarios      Json? // { banco, agencia, conta, tipo, pixChave }
  inscricaoEstadual   String?   @db.VarChar(30)
  porte               String? // 'ME' | 'EPP' | 'medio' | 'grande'
  origemCapital       String? // 'nacional' | 'estrangeiro'
  scoreRelacionamento Int? // 0-1000
  limiteCredito       Decimal?  @db.Decimal(15, 2)
  /// QW5 — workflow de aprovação cadastral
  statusCadastral     String    @default("aprovado") // 'rascunho' | 'analise' | 'aprovado' | 'rejeitado'
  /// S4 M1 — KYC unificado
  kycResultado        Json?
  kycRodadoEm         DateTime?
  kycStatus           String    @default("nao_verificado") // 'nao_verificado'|'aprovado'|'pendencias'|'reprovado'
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  propostas          Proposta[]
  contratos          Contrato[]
  boletos            Boleto[]
  contratosFuturos   ContratoFuturo[]
  cargas             OrdemCarga[]       @relation("ClienteCargas")
  whatsappContacts   WhatsAppContact[]
  // Originação (Epic 1) — produtor recebe adiantamentos
  adiantamentos      Adiantamento[]     @relation("ProdutorAdiantamentos")
  // Compliance (Epic 5)
  talhoes            Talhao[]
  // S4 M1 — propriedades rurais (KYC compliance)
  propriedadesRurais PropriedadeRural[]
  listaSujaEntries   ListaSuja[]
  // S2 M10
  pushSubscriptions  PushSubscription[]
  // S12 M10 — portal produtor (B2C lite)
  produtorAccess     ProdutorAccess?
  documentosProdutor DocumentoProdutor[]
  mensagensProdutor  MensagemProdutor[]

  @@index([email])
  @@index([cnpj])
  @@index([tipo])
  @@index([workspaceId])
}

// ============================================
// S12 M10 — PORTAL PRODUTOR (B2C lite)
// ============================================

model ProdutorAccess {
  id               String    @id @default(cuid())
  workspaceId      String
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clienteId        String    @unique
  cliente          Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  emailLogin       String    @unique
  passwordHash     String?
  tokenInicial     String?   // hash bcrypt do token de setup (1-time)
  acessoCriadoEm   DateTime?
  ultimoLogin      DateTime?
  ativo            Boolean   @default(true)
  twoFactorEnabled Boolean   @default(false)
  totpSecret       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([workspaceId])
}

model DocumentoProdutor {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clienteId    String
  cliente      Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  tipo         String    // 'contrato' | 'nf' | 'cpr' | 'comprovante' | 'outro'
  titulo       String    @db.VarChar(255)
  descricao    String?   @db.Text
  arquivoUrl   String    @db.Text
  arquivoHash  String?   @db.VarChar(128)
  tamanhoBytes Int
  mimeType     String    @db.VarChar(120)
  enviadoPor   String    // 'corretora' | 'produtor'
  uploaderId   String?
  visivel      Boolean   @default(true)
  createdAt    DateTime  @default(now())

  @@index([clienteId, tipo])
  @@index([workspaceId])
}

model MensagemProdutor {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clienteId   String
  cliente     Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  remetente   String    // 'corretora' | 'produtor'
  texto       String    @db.Text
  lidaEm      DateTime?
  createdAt   DateTime  @default(now())

  @@index([clienteId, createdAt])
}

// ============================================
// COTAÇÕES (CBOT via TradingView + Investing.com)
// ============================================

model Cotacao {
  id        String   @id @default(cuid())
  grao      String // 'soja' | 'milho' | 'trigo'
  preco     Decimal  @db.Decimal(10, 2) // cents/bushel — alias de close
  simbolo   String   @db.VarChar(10) // 'ZS' | 'ZC' | 'ZW'
  fonte     String   @default("TradingView") // TradingView | Investing.com
  dolarReal Decimal? @db.Decimal(10, 4) // Taxa USD/BRL nessa hora
  volume    Int? // volume negociado
  // QW7 — OHLC para análise técnica e candlestick
  open      Decimal? @db.Decimal(10, 2)
  high      Decimal? @db.Decimal(10, 2)
  low       Decimal? @db.Decimal(10, 2)
  close     Decimal? @db.Decimal(10, 2)
  data      DateTime @default(now())

  // BH Grain — back-relation: propostas que referenciam esta cotação
  propostasRef Proposta[] @relation("PropostaCotacaoRef")

  @@unique([grao, data])
  @@index([grao])
  @@index([data])
  @@index([simbolo])
}

model TaxaCambio {
  id      String   @id @default(cuid())
  origem  String   @default("USD")
  destino String   @default("BRL")
  taxa    Decimal  @db.Decimal(10, 4)
  fonte   String   @default("Investing.com")
  data    DateTime @default(now())

  @@unique([origem, destino, data])
  @@index([data])
}

// ============================================
// PROPOSTAS COMERCIAIS
// ============================================

model Proposta {
  id           String    @id @default(cuid())
  numero       String    @unique @db.VarChar(50)
  clienteId    String
  cliente      Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  tipo         String // 'venda' | 'compra'
  graos        Json
  valorTotal   Decimal   @db.Decimal(15, 2)
  status       String    @default("rascunho")
  descricao    String?   @db.Text
  observacoes  String?   @db.Text
  criadaEm     DateTime  @default(now())
  enviadaEm    DateTime?
  validadeEm   DateTime
  atualizadaEm DateTime  @updatedAt

  contratos Contrato[]

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // BH Grain — campos opcionais aditivos (Lote 2). UI exibe '—' quando null.
  scoreInterno          Int?
  scoreLabel            String?  // 'alta' | 'media' | 'baixa' | 'risco'
  custoEstimado         Decimal? @db.Decimal(15, 2)
  margemPercent         Decimal? @db.Decimal(6, 3)
  lucroBrutoEstimado    Decimal? @db.Decimal(15, 2)
  cotacaoRefId          String?
  cotacaoRef            Cotacao? @relation("PropostaCotacaoRef", fields: [cotacaoRefId], references: [id], onDelete: SetNull)
  cotacaoFonte          String?  @db.VarChar(60)
  cotacaoCapturadaEm    DateTime?
  validadeCotacao       DateTime?
  marketPriceAtCreation Decimal? @db.Decimal(15, 4)
  lossReason            String?  @db.VarChar(60)
  nextBestAction        String?  @db.VarChar(60)
  nextBestActionReason  String?  @db.Text

  // BH Grain — Logística (Lote 12 / Fase F)
  origem            String?  @db.VarChar(120)
  destino           String?  @db.VarChar(120)
  localEntrega      String?  @db.VarChar(120)
  modalTransporte   String?  @db.VarChar(20)  // 'rodoviario' | 'ferroviario' | 'hidroviario' | 'multimodal'
  freteTipo         String?  @db.VarChar(20)  // 'incluso' | 'comprador' | 'vendedor' | 'definir'
  freteCustoTotal   Decimal? @db.Decimal(15, 2)
  freteCustoUnit    Decimal? @db.Decimal(15, 4)
  prazoLogistico    DateTime?
  incoterm          String?  @db.VarChar(10)
  armazemOrigemRefId  String?
  armazemOrigemRef    Armazem? @relation("PropostaArmazemOrigem", fields: [armazemOrigemRefId], references: [id], onDelete: SetNull)
  armazemDestinoRefId String?
  armazemDestinoRef   Armazem? @relation("PropostaArmazemDestino", fields: [armazemDestinoRefId], references: [id], onDelete: SetNull)

  // BH Grain — Estoque vinculado (Lote 12 / Fase F)
  loteEstoqueRefId String?
  loteEstoqueRef   LoteEstoque? @relation("PropostaLoteEstoque", fields: [loteEstoqueRefId], references: [id], onDelete: SetNull)

  // BH Grain — Qualidade (Lote 12 / Fase F)
  /// JSON estruturado: { umidadeMax?, impurezaMax?, ph?, proteinaMin?, ardidosMax?, avariadosMax?, padraoComercial?, observacoes? }
  qualidadeSpec    Json?

  @@index([clienteId])
  @@index([status])
  @@index([validadeEm])
  @@index([workspaceId])
  @@index([cotacaoRefId])
  @@index([armazemOrigemRefId])
  @@index([armazemDestinoRefId])
  @@index([loteEstoqueRefId])

  // S10 M2 — origem em Oferta aceita (1:1 oferta → 1 proposta)
  ofertaOrigem Oferta?
}

// ============================================
// CONTRATOS
// ============================================

model Contrato {
  id               String    @id @default(cuid())
  numero           String    @unique @db.VarChar(50)
  proposIdFk       String
  proposta         Proposta  @relation(fields: [proposIdFk], references: [id], onDelete: Cascade)
  clienteId        String
  cliente          Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  dataInicio       DateTime
  dataFim          DateTime?
  pdfUrl           String?   @db.Text
  assinadoEm       DateTime?
  statusAssinatura String    @default("pendente")
  // QW8 — versionamento imutável do PDF (SHA-256)
  pdfHash          String?
  pdfHashedAt      DateTime?
  criadoEm         DateTime  @default(now())
  atualizadoEm     DateTime  @updatedAt

  boletos     Boleto[]
  ordensCarga OrdemCarga[]

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Modalidade — preço fixo, a fixar, misto, barter ou triangular
  modalidade String @default("fixo") // 'fixo' | 'a_fixar' | 'misto' | 'barter' | 'triangular'

  // Operação triangular: este contrato pode ser filho de outro (mesma origem)
  contratoOriginalId String?
  contratoOriginal   Contrato?  @relation("OperacaoTriangular", fields: [contratoOriginalId], references: [id], onDelete: SetNull)
  contratosFilhos    Contrato[] @relation("OperacaoTriangular")

  // S2 M10
  aceite AceiteContrato?

  // S3 M3 — Snapshot imutável da versão de template usada na geração
  templateVersaoSnapshot Json?
  templateVersaoId       String?

  // S3 M3 — Forma + prazo de pagamento, local de entrega
  formaPagamento     String? // 'a_vista'|'parcelado'|'30_60_90'|'safra'|'misto'
  prazoPagamentoDias Int?
  localEntrega       String?

  // S3 M3 — Cláusulas customizáveis + assinatura digital + notificações
  clausulas         ClausulaContrato[]
  assinaturaDigital AssinaturaDigital?
  notificacoes      ContratoNotificacao[]

  // Originação (Epic 1)
  fixacao                ContratoFixacao?
  adiantamentos          Adiantamento[]
  barterInsumos          BarterInsumo[]
  washouts               Washout[]
  // Hedge (Epic 4): hedge financeiro vinculado a este contrato físico
  posicoesHedge          PosicaoHedge[]          @relation("HedgeContrato")
  // Fiscal (Epic 3)
  notasFiscais           NotaFiscal[]
  // Compliance (Epic 5)
  movimentosFinanceiros  MovimentoFinanceiro[]
  royalties              Royalty[]
  // S5 M9 EUDR
  duediligenceStatements DueDiligenceStatement[]
  /// Status próprio do contrato — quando há workflow de aprovação ativo
  statusAprovacao        String                  @default("aprovado") // 'pendente_aprovacao' | 'aprovado' | 'rejeitado'

  // S6 M5 — atribuição hierárquica
  corretorId String?
  mesaId     String?

  @@index([clienteId])
  @@index([proposIdFk])
  @@index([assinadoEm])
  @@index([workspaceId])
  @@index([contratoOriginalId])
}

// ============================================
// BOLETOS DE COBRANÇA
// ============================================

model Boleto {
  id           String    @id @default(cuid())
  numero       String    @unique @db.VarChar(50)
  contratoIdFk String?
  contrato     Contrato? @relation(fields: [contratoIdFk], references: [id], onDelete: SetNull)
  clienteId    String
  cliente      Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  banco        String    @db.VarChar(20)
  valor        Decimal   @db.Decimal(15, 2)
  vencimento   DateTime
  status       String    @default("aberto")
  linkBoleto   String?   @db.Text
  braspagId    String?   @db.VarChar(100)
  confirmadoEm DateTime?
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Compliance (Epic 5)
  movimentosFinanceiros MovimentoFinanceiro[]

  @@index([clienteId])
  @@index([status])
  @@index([vencimento])
  @@index([braspagId])
  @@index([workspaceId])
}

// ============================================
// WEBHOOKS LOG (auditoria)
// ============================================

model WebhookLog {
  id         String   @id @default(cuid())
  tipo       String
  payload    Json
  status     String   @default("recebido")
  mensagem   String?  @db.Text
  codigoErro String?  @db.VarChar(50)
  ipOrigem   String?  @db.VarChar(50)
  timestamp  DateTime @default(now())
  criadoEm   DateTime @default(now())

  @@index([tipo])
  @@index([status])
  @@index([timestamp])
  @@index([criadoEm])
}

// ============================================
// EMAIL VERIFICATION & PASSWORD RESET
// ============================================

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  criadoEm  DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  criadoEm  DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// ============================================
// AUDITORIA DE AÇÕES
// ============================================

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  acao        String
  entidade    String
  entidadeId  String
  mudancas    Json?
  ipAddress   String?
  userAgent   String?
  /// QW3 — workspaceId opcional (eventos sem workspace: signup, login)
  workspaceId String?
  criadoEm    DateTime @default(now())

  @@index([userId])
  @@index([entidade])
  @@index([criadoEm])
  @@index([workspaceId])
}

// ============================================
// CACHE DE DADOS (Investing.com, etc)
// ============================================

model CacheData {
  id          String   @id @default(cuid())
  chave       String   @unique @db.VarChar(255)
  valor       Json
  expiracaoEm DateTime
  criadoEm    DateTime @default(now())

  @@index([expiracaoEm])
}

// ============================================
// PRICING CMS (planos dinâmicos editáveis)
// ============================================

model Plan {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  description     String?
  badge           String?
  highlight       Boolean  @default(false)
  priceCents      Int
  currency        String   @default("BRL")
  billingInterval String   @default("month")
  intervalCount   Int      @default(1)
  trialDays       Int      @default(10)
  ctaLabel        String   @default("Iniciar trial")
  ctaHref         String?
  tagline         String?
  sortOrder       Int      @default(0)
  active          Boolean  @default(true)
  stripeProductId String?  @unique
  stripePriceId   String?
  legacyPriceIds  String[] @default([])

  // Membros
  includedMembers        Int     @default(1)
  extraMemberPriceCents  Int     @default(15000)
  stripeExtraSeatPriceId String?

  /// Disponibilidade do agente AI no plano:
  /// 'none' = sem AI; 'managed' = AI com chave da plataforma (limites por plano);
  /// 'byok_allowed' = AI managed + opcional cliente trazer chave própria (Enterprise)
  aiAccess           String @default("none")
  /// Limite de mensagens AI / mês quando aiAccess='managed' (0 = ilimitado)
  aiMonthlyMessages  Int    @default(0)

  features  PlanFeature[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([active, sortOrder])
}

model PlanFeature {
  id        String   @id @default(cuid())
  planId    String
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  label     String
  included  Boolean  @default(true)
  emphasis  Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([planId, sortOrder])
}

model PricingRevision {
  id        Int      @id @default(1)
  revision  Int      @default(1)
  updatedAt DateTime @updatedAt
}

// ============================================
// CONTRATOS FUTUROS (Book B3 próprio)
// ============================================

model ContratoFuturo {
  id           String    @id @default(cuid())
  /// LEGADO — será removido após backfill
  usuarioId    String?
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  grao         String // 'soja' | 'milho' | 'trigo' | 'sorgo'
  lado         String // 'compra' (bid) | 'venda' (ask)
  vencimento   DateTime  @db.Date
  precoSc      Decimal   @db.Decimal(10, 2)
  volumeSc     Int
  /// Codigo de vencimento estilo B3: K26 (mai/26), N26 (jul/26), X26 (nov/26)
  codigoVenc   String?   @db.VarChar(10)
  praca        String?   @db.VarChar(100)
  observacao   String?   @db.Text
  status       String    @default("ativo") // 'ativo' | 'executado' | 'cancelado'
  clienteId    String?
  cliente      Cliente?  @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt

  @@index([workspaceId, grao, status])
  @@index([vencimento])
}

// ============================================
// LOGÍSTICA — Armazéns, Motoristas, Ordens de Carga
// ============================================

model Armazem {
  id            String        @id @default(cuid())
  workspaceId   String
  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  nome          String
  tipo          String // 'silo' | 'granel' | 'horizontal' | 'misto'
  capacidadeSc  Int // capacidade em sacas 60kg
  endereco      String?
  cidade        String?
  uf            String?       @db.VarChar(2)
  cep           String?       @db.VarChar(10)
  contato       String?
  telefone      String?
  observacao    String?       @db.Text
  ativo         Boolean       @default(true)
  /// Próprio (galpão da empresa) ou terceirizado (Fornecedor)
  proprio       Boolean       @default(true)
  fornecedorId  String?
  fornecedor    Fornecedor?   @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)
  ordensOrigem  OrdemCarga[]  @relation("ArmazemOrigem")
  ordensDestino OrdemCarga[]  @relation("ArmazemDestino")
  // Operação Física (Epic 2)
  balancas      Balanca[]
  lotesEstoque  LoteEstoque[]
  // BH Grain (Fase F) — propostas que indicam este armazém como origem/destino
  propostasOrigem  Proposta[] @relation("PropostaArmazemOrigem")
  propostasDestino Proposta[] @relation("PropostaArmazemDestino")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([workspaceId, ativo])
  @@index([fornecedorId])
}

model Motorista {
  id               String          @id @default(cuid())
  workspaceId      String
  workspace        Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  nome             String
  cpf              String?         @db.VarChar(14)
  cnh              String?         @db.VarChar(20)
  cnhCategoria     String?         @db.VarChar(5)
  telefone         String?
  whatsapp         String?
  email            String?
  /// Veículo padrão
  placa            String?         @db.VarChar(10)
  veiculo          String?
  capacidadeSc     Int?
  /// Vinculado a uma transportadora (Fornecedor)
  transportadoraId String?
  transportadora   Fornecedor?     @relation("TransportadoraMotoristas", fields: [transportadoraId], references: [id], onDelete: SetNull)
  observacao       String?         @db.Text
  ativo            Boolean         @default(true)
  ordens           OrdemCarga[]
  // Operação Física (Epic 2)
  romaneios        Romaneio[]
  ticketsBalanca   TicketBalanca[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([workspaceId, ativo])
  @@index([transportadoraId])
}

model OrdemCarga {
  id               String      @id @default(cuid())
  numero           String      @unique
  workspaceId      String
  workspace        Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contratoId       String?
  contrato         Contrato?   @relation(fields: [contratoId], references: [id], onDelete: SetNull)
  clienteId        String?
  cliente          Cliente?    @relation("ClienteCargas", fields: [clienteId], references: [id], onDelete: SetNull)
  motoristaId      String?
  motorista        Motorista?  @relation(fields: [motoristaId], references: [id], onDelete: SetNull)
  transportadoraId String?
  transportadora   Fornecedor? @relation("TransportadoraOrdens", fields: [transportadoraId], references: [id], onDelete: SetNull)
  armazemOrigemId  String?
  armazemOrigem    Armazem?    @relation("ArmazemOrigem", fields: [armazemOrigemId], references: [id], onDelete: SetNull)
  armazemDestinoId String?
  armazemDestino   Armazem?    @relation("ArmazemDestino", fields: [armazemDestinoId], references: [id], onDelete: SetNull)
  grao             String // 'soja' | 'milho' | 'trigo' | 'sorgo'
  quantidadeSc     Int
  pesoToneladas    Decimal?    @db.Decimal(10, 2)
  /// Datas
  dataAgendada     DateTime
  dataCarregamento DateTime?
  dataDescarga     DateTime?
  /// CT-e
  ctEnumero        String?     @db.VarChar(50)
  ctEpdfUrl        String?     @db.Text
  ctEdataEmissao   DateTime?
  /// Status
  status           String      @default("agendada")
  observacao       String?     @db.Text
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([workspaceId, status])
  @@index([dataAgendada])
  @@index([motoristaId])
  @@index([transportadoraId])
  @@index([contratoId])
}

// ============================================
// OPERAÇÃO FÍSICA (Epic 2) — Safra, Lotes, Romaneios, Balança, Classificação
// ============================================

model Safra {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  nome    String // ex "2024/25"
  cultura String // 'soja' | 'milho' | 'trigo'
  inicio  DateTime
  fim     DateTime
  ativa   Boolean  @default(true)

  romaneios             Romaneio[]
  ticketsBalanca        TicketBalanca[]
  lotes                 LoteEstoque[]
  planosVendas          PlanoVendas[]
  // Compliance (Epic 5)
  movimentosFinanceiros MovimentoFinanceiro[]
  talhoes               Talhao[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, nome, cultura])
  @@index([workspaceId, ativa])
}

model TabelaClassificacao {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  cultura String
  nome    String

  umidadePadrao     Float
  umidadeMaxima     Float
  impurezaPadrao    Float
  impurezaMaxima    Float
  ardidosMaximo     Float
  quebradosMaximo   Float
  esverdeadosMaximo Float?
  pesoHectolitroMin Float?

  fatorDescontoUmidade   Float @default(1.0)
  fatorDescontoImpureza  Float @default(1.0)
  fatorDescontoArdidos   Float @default(2.0)
  fatorDescontoQuebrados Float @default(0.5)

  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, cultura, nome])
  @@index([workspaceId, cultura, ativo])
}

model Balanca {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  nome       String
  modelo     String?
  fabricante String?

  armazemId String?
  armazem   Armazem? @relation(fields: [armazemId], references: [id], onDelete: SetNull)

  capacidadeMaxKg    Int     @default(80000)
  precisaoKg         Int     @default(20)
  tipoIntegracao     String  @default("manual") // manual | serial | tcp | api
  enderecoIntegracao String?

  ativa     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticketsBalanca TicketBalanca[]

  @@index([workspaceId, ativa])
  @@index([armazemId])
}

model LoteEstoque {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  numero  String
  cultura String
  safraId String?
  safra   Safra?  @relation(fields: [safraId], references: [id], onDelete: SetNull)

  armazemId String
  armazem   Armazem @relation(fields: [armazemId], references: [id], onDelete: Restrict)

  qtdInicialSc Float
  qtdAtualSc   Float

  umidadeMedia  Float?
  impurezaMedia Float?

  status String @default("ativo") // ativo | consumido | transferido

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticketsBalanca TicketBalanca[]
  movimentacoes  MovimentacaoLote[]
  // S5 M9 EUDR
  talhaoLotes    TalhaoLote[]
  // BH Grain (Fase F) — propostas que reservam volume deste lote
  propostasRef   Proposta[]   @relation("PropostaLoteEstoque")

  @@unique([workspaceId, numero])
  @@index([workspaceId, cultura, status])
  @@index([armazemId])
}

model Romaneio {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  numero String

  contratosIds String[]

  motoristaId String?
  motorista   Motorista? @relation(fields: [motoristaId], references: [id], onDelete: SetNull)

  origem  String
  destino String

  cultura String
  safraId String?
  safra   Safra?  @relation(fields: [safraId], references: [id], onDelete: SetNull)

  status String @default("rascunho") // rascunho | em_transito | recebido | cancelado

  dataSaida   DateTime?
  dataChegada DateTime?

  observacoes String? @db.Text

  // S7 M4 — QR público pra conferência na portaria
  qrTokenHash     String?
  qrTokenExpiraEm DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticketsBalanca TicketBalanca[]
  notasFiscais   NotaFiscal[]

  @@unique([workspaceId, numero])
  @@index([workspaceId, status])
  @@index([motoristaId])
  @@index([qrTokenHash])
}

model TicketBalanca {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  numero String
  tipo   String // recepcao | expedicao | transferencia

  romaneioId String?
  romaneio   Romaneio? @relation(fields: [romaneioId], references: [id], onDelete: SetNull)

  balancaId String?
  balanca   Balanca? @relation(fields: [balancaId], references: [id], onDelete: SetNull)

  loteId String?
  lote   LoteEstoque? @relation(fields: [loteId], references: [id], onDelete: SetNull)

  pesoBrutoKg   Float
  taraKg        Float
  pesoLiquidoKg Float

  cultura String
  safraId String?
  safra   Safra?  @relation(fields: [safraId], references: [id], onDelete: SetNull)

  classificacaoId String?
  classificacao   Classificacao? @relation(fields: [classificacaoId], references: [id], onDelete: SetNull)

  placa       String?
  motoristaId String?
  motorista   Motorista? @relation(fields: [motoristaId], references: [id], onDelete: SetNull)

  fotoUrl     String?
  observacoes String? @db.Text

  status String @default("aberto") // aberto | classificado | finalizado

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // S5 M9 EUDR
  talhaoLotes TalhaoLote[]

  @@unique([workspaceId, numero])
  @@index([workspaceId, status, tipo])
  @@index([romaneioId])
  @@index([loteId])
}

model Classificacao {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  cultura String

  umidade          Float
  impureza         Float
  ardidos          Float  @default(0)
  quebrados        Float  @default(0)
  esverdeados      Float?
  pesoHectolitroKg Float?

  tabelaId String?

  descontoUmidadePct   Float @default(0)
  descontoImpurezaPct  Float @default(0)
  descontoArdidosPct   Float @default(0)
  descontoQuebradosPct Float @default(0)
  // S7 M4 — avariados generic (mofados/manchados/picados etc. consolidados)
  avariadosGeral       Float @default(0)
  descontoAvariadosPct Float @default(0)
  descontoTotalPct     Float @default(0)

  pesoLiquidoFinalKg Float?

  classificadoPor String?
  observacoes     String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticketsBalanca TicketBalanca[]

  @@index([workspaceId, cultura])
}

model MovimentacaoLote {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  loteId String
  lote   LoteEstoque @relation(fields: [loteId], references: [id], onDelete: Cascade)

  tipo  String // entrada | saida | transferencia | quebra_tecnica | rebaixe
  qtdSc Float

  armazemDestinoId String?
  ticketBalancaId  String?
  contratoId       String?

  motivo String? @db.Text

  createdAt DateTime @default(now())

  @@index([workspaceId, loteId])
  @@index([tipo])
}

// ============================================
// WHATSAPP INSTÂNCIA (Evolution API por workspace)
// ============================================

model WhatsAppInstance {
  id          String    @id @default(cuid())
  workspaceId String    @unique
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  instanceName String  @unique
  evolutionId  String?
  status       String  @default("disconnected") // disconnected|connecting|connected|error

  phoneNumber   String?
  phoneJid      String?
  profileName   String?
  profilePicUrl String?

  connectedAt    DateTime?
  disconnectedAt DateTime?
  lastQrAt       DateTime?

  webhookSecret String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// ============================================
// WHATSAPP CONVERSAS (Contatos + Mensagens)
// ============================================

model WhatsAppContact {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  jid           String // ex: "5551999999999@s.whatsapp.net"
  phone         String? // só dígitos: "5551999999999"
  pushName      String? // nome que ele se identifica
  profilePicUrl String?

  // Vínculo opcional com Cliente/Fornecedor existente
  clienteId    String?
  cliente      Cliente?    @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  fornecedorId String?
  fornecedor   Fornecedor? @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)

  lastMessageAt DateTime?
  unreadCount   Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages WhatsAppMessage[]

  @@unique([workspaceId, jid])
  @@index([workspaceId, lastMessageAt])
  @@index([clienteId])
  @@index([fornecedorId])
}

model WhatsAppMessage {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  contactId String
  contact   WhatsAppContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  // Identificadores Evolution/WhatsApp
  messageId String // ID único da mensagem no WhatsApp (key.id)
  remoteJid String // JID do contact ou grupo
  fromMe    Boolean // true = enviada pela corretora, false = recebida

  // Conteúdo
  text         String? @db.Text
  mediaType    String? // image|video|audio|document|sticker|null
  mediaUrl     String?
  mediaCaption String?

  // Reply / quote
  replyToMessageId String?

  status String @default("delivered") // pending|sent|delivered|read|failed

  // Timestamps
  timestamp DateTime // timestamp do WhatsApp
  createdAt DateTime @default(now())

  @@unique([workspaceId, messageId]) // idempotência
  @@index([workspaceId, contactId, timestamp])
  @@index([workspaceId, timestamp])
}

// ============================================
// ORIGINAÇÃO & FIXAÇÃO (Epic 1)
// ============================================

/// Configuração de fixação de um contrato (apenas para modalidade "a_fixar" / "misto").
model ContratoFixacao {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  contratoId String   @unique
  contrato   Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  modalidade String // 'fixo' | 'a_fixar' | 'misto' | 'barter' | 'triangular'

  qtdTotalSc        Float
  qtdFixadaSc       Float @default(0)
  qtdRemanescenteSc Float

  fixacaoInicio DateTime?
  fixacaoFim    DateTime?

  gatilhoTipo    String? // 'preco_alvo' | 'manual' | 'data_limite'
  gatilhoPrecoSc Float?
  gatilhoCultura String? // 'soja' | 'milho' | 'trigo'

  statusFixacao String @default("pendente") // 'pendente' | 'parcial' | 'totalmente_fixado' | 'cancelado'

  observacoes String? @db.Text

  fixacoes Fixacao[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, statusFixacao])
}

/// Cada fixação parcial de preço sobre um ContratoFixacao.
model Fixacao {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  contratoFixacaoId String
  contratoFixacao   ContratoFixacao @relation(fields: [contratoFixacaoId], references: [id], onDelete: Cascade)

  qtdSc         Float
  precoSc       Float
  precoUSDSc    Float?
  cotacaoUSDBRL Float?
  premio        Float?
  base          Float?

  fixadoEm  DateTime @default(now())
  fixadoPor String?

  observacoes String? @db.Text
  pdfUrl      String?

  createdAt DateTime @default(now())

  @@index([contratoFixacaoId, fixadoEm])
  @@index([workspaceId])
}

/// Adiantamento ao produtor (cash ou insumo) — quitado pela entrega física.
model Adiantamento {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  numero String

  contratoId String
  contrato   Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  produtorId String
  produtor   Cliente @relation("ProdutorAdiantamentos", fields: [produtorId], references: [id], onDelete: Restrict)

  valor Decimal @db.Decimal(15, 2)

  tipo String // 'dinheiro' | 'insumo' | 'misto'

  dataAdiantamento DateTime  @default(now())
  dataPrevistaQuit DateTime?

  qtdAbatidaSc  Float @default(0)
  qtdEsperadaSc Float

  status String @default("aberto") // 'aberto' | 'parcial' | 'quitado' | 'inadimplente'

  observacoes String? @db.Text

  itensInsumo BarterInsumo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, numero])
  @@index([workspaceId, status])
  @@index([produtorId])
  @@index([contratoId])
}

/// Insumo entregue ao produtor (barter) — convertido em sacas equivalentes.
model BarterInsumo {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  adiantamentoId String?
  adiantamento   Adiantamento? @relation(fields: [adiantamentoId], references: [id], onDelete: SetNull)

  contratoId String
  contrato   Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  descricao    String
  fornecedorId String?
  fornecedor   Fornecedor? @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)

  quantidade Float
  unidade    String // 'kg' | 'l' | 'sc' | 'un'
  precoUnit  Decimal @db.Decimal(10, 2)
  valorTotal Decimal @db.Decimal(15, 2)

  precoFixadoSc        Float
  qtdGraoEquivalenteSc Float

  status String @default("pendente") // 'pendente' | 'entregue' | 'recebido_grao' | 'cancelado'

  dataEntregaInsumo DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, status])
  @@index([contratoId])
  @@index([adiantamentoId])
  @@index([fornecedorId])
}

/// Plano de vendas / forecast por safra+cultura.
model PlanoVendas {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  safraId String?
  safra   Safra?  @relation(fields: [safraId], references: [id], onDelete: SetNull)

  cultura String

  qtdPrevistaSc   Float
  qtdContratadaSc Float @default(0)
  qtdFixadaSc     Float @default(0)
  qtdEntregueSc   Float @default(0)

  precoMedioPrevistoSc Float?

  observacoes String? @db.Text

  status String @default("ativo") // 'ativo' | 'concluido' | 'cancelado'

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, cultura, safraId])
  @@index([workspaceId, status])
}

/// Washout — desfazimento de contrato com motivo e custo associado.
model Washout {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  contratoId String
  contrato   Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  motivo          String // 'cliente_desistiu' | 'forcas_maior' | 'preco_inviavel' | 'outro'
  motivoDescricao String? @db.Text

  custoWashout  Decimal @default(0) @db.Decimal(15, 2)
  custoQuemPaga String? // 'comprador' | 'vendedor' | 'corretora'

  qtdAfetadaSc Float

  aprovadoPor String?

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([contratoId])
}

// ============================================
// EPIC 4 — HEDGE & RISCO
// (Long/Short, NDF, Marcação a Mercado, Multi-moeda)
// ============================================

/// Posição de hedge financeiro (Long ou Short).
/// IMPORTANTE: distinta de `ContratoFuturo` — ContratoFuturo modela negócio
/// comercial (cliente compra/vende lote físico futuro). PosicaoHedge é operação
/// financeira pura na bolsa (CBOT/B3) usada como instrumento de proteção.
model PosicaoHedge {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  numero String // ex 'HDG-2024-001'
  tipo   String // 'long' | 'short'

  cultura        String? // 'soja' | 'milho' | 'trigo' (null se hedge cambial puro)
  contratoFuturo String // 'ZS' | 'ZC' | 'ZW' (CBOT) ou 'SBM' (B3)
  vencimento     DateTime // mês de vencimento (1º dia)

  qtdContratos     Float // num contratos futuros (1 contrato CBOT soja = 5000 bushels = 136 t)
  qtdEquivalenteSc Float // qtd em sacas equivalente (calculada)

  // Preços
  precoEntradaUsdBu Decimal? @db.Decimal(10, 4) // CBOT: USD/bushel
  precoEntradaBrlSc Decimal? @db.Decimal(10, 2) // BR: R$/sc

  // Câmbio na entrada (importante pra P&L)
  cambioEntradaUsdBrl Decimal? @db.Decimal(10, 4)

  // Margem inicial / depositada
  margemDepositadaUSD Decimal? @db.Decimal(15, 2)
  margemDepositadaBRL Decimal? @db.Decimal(15, 2)

  // Custos
  corretagemUSD Decimal @default(0) @db.Decimal(10, 2)

  // Vínculos
  contratoOrigemId String?
  contratoOrigem   Contrato? @relation("HedgeContrato", fields: [contratoOrigemId], references: [id], onDelete: SetNull)

  status String @default("aberta") // 'aberta' | 'fechada' | 'rolada' | 'liquidada'

  abertoEm  DateTime  @default(now())
  fechadoEm DateTime?

  // Quando fechado
  precoSaidaUsdBu   Decimal? @db.Decimal(10, 4)
  precoSaidaBrlSc   Decimal? @db.Decimal(10, 2)
  cambioSaidaUsdBrl Decimal? @db.Decimal(10, 4)
  pnlFinalUSD       Decimal? @db.Decimal(15, 2)
  pnlFinalBRL       Decimal? @db.Decimal(15, 2)

  observacoes String? @db.Text

  // S6 M5 — atribuição hierárquica
  corretorId String?
  mesaId     String?

  marcacoes MarcacaoMercado[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, numero])
  @@index([workspaceId, status])
  @@index([cultura, vencimento])
  @@index([contratoOrigemId])
  @@index([corretorId])
  @@index([mesaId])
}

/// NDF — Non-Deliverable Forward (moeda ou commodity).
model NDF {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  numero String
  tipo   String // 'moeda' | 'commodity'

  contraparteNome String
  contraparteCnpj String?

  direcao   String // 'compra' | 'venda'
  ativoTipo String // 'USDBRL' | 'EURBRL' | 'ZS' | 'ZC' | 'ZW' ...

  notional Decimal @db.Decimal(15, 2) // valor de referência
  strike   Decimal @db.Decimal(10, 4) // taxa contratada

  dataAbertura   DateTime @default(now())
  dataVencimento DateTime

  status String @default("aberta") // 'aberta' | 'liquidada' | 'cancelada'

  precoLiquidacao Decimal? @db.Decimal(10, 4)
  resultadoBRL    Decimal? @db.Decimal(15, 2)

  observacoes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, numero])
  @@index([workspaceId, status])
  @@index([dataVencimento])
}

/// Marcação a Mercado — snapshot diário das posições abertas.
model MarcacaoMercado {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  posicaoHedgeId String
  posicaoHedge   PosicaoHedge @relation(fields: [posicaoHedgeId], references: [id], onDelete: Cascade)

  data DateTime // dia da marcação

  precoMercadoUsdBu Decimal? @db.Decimal(10, 4)
  precoMercadoBrlSc Decimal? @db.Decimal(10, 2)
  cambioUsdBrl      Decimal? @db.Decimal(10, 4)

  pnlUnrealizedUSD Decimal @db.Decimal(15, 2)
  pnlUnrealizedBRL Decimal @db.Decimal(15, 2)

  variacaoDiaUSD Decimal? @db.Decimal(15, 2)
  variacaoDiaBRL Decimal? @db.Decimal(15, 2)

  // S6 M5 — Auditoria de cálculo (qual cotação/câmbio/formula foi usada)
  inputsSnapshot Json?
  calcMetodo     String?
  calcVersao     String? @default("v1")

  createdAt DateTime @default(now())

  @@unique([posicaoHedgeId, data])
  @@index([workspaceId, data])
}

// ============================================
// EPIC 3 — FISCAL (NF-e + SPED)
// ============================================

model ConfiguracaoFiscal {
  id          String    @id @default(cuid())
  workspaceId String    @unique
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Dados emissor
  cnpjEmissor        String
  inscricaoEstadual  String?
  inscricaoMunicipal String?
  regimeTributario   String // 'simples_nacional' | 'lucro_presumido' | 'lucro_real' | 'mei'
  cnae               String?

  // Provider config
  providerNome      String  @default("mock") // 'mock' | 'nfeio' | 'enotas' | 'webmania' | 'tecnospeed'
  providerCompanyId String?
  ambiente          String  @default("homologacao") // 'homologacao' | 'producao'

  // Certificado A1 (Supabase Storage URL)
  certificadoUrl        String?
  certificadoVencimento DateTime?
  certificadoAlias      String?

  // Padrões NF-e
  serieNFe             Int  @default(1)
  proximoNumeroNFe     Int  @default(1)
  serieNFeContingencia Int?

  // Padrões fiscais
  cfopCompraProdutorPF   String @default("1102")
  cfopCompraProdutorPJ   String @default("1102")
  cfopVendaInterestadual String @default("6101")
  cfopVendaIntraestadual String @default("5101")

  // FUNRURAL
  funruralAplicar  Boolean @default(true)
  funruralAliquota Float   @default(1.3)

  // SPED
  cnaeSped String?

  ativo Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notasFiscais NotaFiscal[]
}

model NotaFiscal {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  configFiscalId String
  configFiscal   ConfiguracaoFiscal @relation(fields: [configFiscalId], references: [id], onDelete: Cascade)

  // Tipo / modelo
  tipo   String // 'entrada' | 'saida' | 'devolucao' | 'complementar' | 'triangular'
  modelo String @default("55") // 55 = NF-e, 65 = NFC-e

  // Numeração
  serie     Int
  numero    Int
  chave     String? @unique
  protocolo String?

  // Status SEFAZ
  status         String  @default("rascunho")
  // 'rascunho' | 'enviada' | 'autorizada' | 'rejeitada' | 'cancelada' | 'inutilizada' | 'denegada'
  motivoRejeicao String? @db.Text

  // Datas
  dataEmissao      DateTime  @default(now())
  dataAutorizacao  DateTime?
  dataCancelamento DateTime?

  // Vínculos
  contratoId  String?
  contrato    Contrato? @relation(fields: [contratoId], references: [id], onDelete: SetNull)
  romaneioId  String?
  romaneioRel Romaneio? @relation(fields: [romaneioId], references: [id], onDelete: SetNull)

  // Emitente snapshot
  emitenteCnpj String
  emitenteNome String
  emitenteUF   String

  // Destinatário snapshot
  destinatarioDoc  String
  destinatarioNome String
  destinatarioUF   String
  destinatarioIE   String?

  // Itens (JSON)
  itens Json

  // Totais
  valorProdutos Decimal @db.Decimal(15, 2)
  valorICMS     Decimal @default(0) @db.Decimal(15, 2)
  valorPIS      Decimal @default(0) @db.Decimal(15, 2)
  valorCOFINS   Decimal @default(0) @db.Decimal(15, 2)
  valorFUNRURAL Decimal @default(0) @db.Decimal(15, 2)
  valorFrete    Decimal @default(0) @db.Decimal(15, 2)
  valorOutros   Decimal @default(0) @db.Decimal(15, 2)
  valorTotal    Decimal @db.Decimal(15, 2)

  cfopPrincipal     String
  naturezaOperacao  String
  finalidadeEmissao String @default("1")

  intermunicipal Boolean @default(false)
  interestadual  Boolean @default(false)

  // Triangular
  notaPaiId   String?
  notaPaiRel  NotaFiscal?  @relation("NotaTriangular", fields: [notaPaiId], references: [id], onDelete: SetNull)
  notasFilhas NotaFiscal[] @relation("NotaTriangular")

  // Diferimento ICMS
  diferimentoICMS Boolean @default(false)

  // Provider
  providerResponse Json?
  providerNFeId    String?

  // PDFs / XMLs
  xmlUrl   String?
  danfeUrl String?

  observacoes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cartasCorrecao CartaCorrecao[]

  @@unique([workspaceId, serie, numero])
  @@index([workspaceId, status])
  @@index([dataEmissao])
  @@index([chave])
  @@index([contratoId])
}

model CartaCorrecao {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  notaFiscalId String
  notaFiscal   NotaFiscal @relation(fields: [notaFiscalId], references: [id], onDelete: Cascade)

  sequencia Int
  texto     String @db.Text

  status    String  @default("rascunho") // 'rascunho' | 'aceita' | 'rejeitada'
  protocolo String?
  motivo    String? @db.Text

  dataAceite DateTime?

  createdAt DateTime @default(now())

  @@unique([notaFiscalId, sequencia])
}

model SpedExport {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  tipo        String // 'fiscal' | 'contribuicoes' | 'ecd' | 'ecf'   (S9 M7: ECD/ECF anuais)
  competencia String // 'YYYYMM'

  arquivoUrl     String?
  totalRegistros Int     @default(0)

  status  String  @default("processando") // 'processando' | 'pronto' | 'erro'
  erroMsg String? @db.Text

  hashArquivo String?

  geradoEm DateTime?

  createdAt DateTime @default(now())

  @@unique([workspaceId, tipo, competencia])
  @@index([workspaceId])
}

/// S9 M7 — Guia de arrecadação (DARF/GNRE/GARE).
model Guia {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  numero String // sequencial por workspace
  tipo   String // 'darf' | 'gnre' | 'gare'

  codigoReceita    String
  contribuinteDoc  String // CPF/CNPJ
  contribuinteNome String

  periodoApuracao String   // 'YYYYMM' ou data
  valorPrincipal  Decimal  @db.Decimal(15, 2)
  multa           Decimal  @default(0) @db.Decimal(15, 2)
  juros           Decimal  @default(0) @db.Decimal(15, 2)
  valorTotal      Decimal  @db.Decimal(15, 2)

  vencimento DateTime

  codigoBarras    String?
  linhaDigitavel  String?

  status  String    @default("aberto") // 'aberto' | 'pago' | 'cancelado'
  pagoEm  DateTime?

  uf String? // GNRE / GARE

  referenciaContratoId String?

  observacoes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, numero])
  @@index([workspaceId, tipo, status])
  @@index([workspaceId, vencimento])
}

// ============================================
// COMPLIANCE & ESCALA (Epic 5) — Aprovação multi-nível, DRE, Conciliação, Talhões, Royalties
// ============================================

/// Workflow de aprovação multi-nível por entidade.
model AprovacaoWorkflow {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  nome      String
  descricao String? @db.Text

  /// Entidade que dispara workflow: 'contrato' | 'fixacao' | 'washout' | 'adiantamento' | 'nf_emissao'
  entidade String
  /// JSON com condições, ex: { "valorMinimo": 500000 } ou { "qtdMinimaSc": 5000 }
  condicao Json
  /// Array ordenado de etapas: [{ ordem, role, nome }]
  etapas   Json

  slaHoras Int     @default(48)
  ativo    Boolean @default(true)

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  aprovacoes Aprovacao[]

  @@index([workspaceId, entidade, ativo])
}

/// Instância de aprovação em curso ou finalizada.
model Aprovacao {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  workflowId String
  workflow   AprovacaoWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  entidadeTipo String
  entidadeId   String

  snapshot Json

  etapaAtual  Int @default(1)
  totalEtapas Int

  /// 'pendente' | 'aprovada' | 'rejeitada' | 'cancelada' | 'expirada'
  status String @default("pendente")

  solicitanteId String
  solicitante   User   @relation("AprovacaoSolicitante", fields: [solicitanteId], references: [id], onDelete: Restrict)

  prazoEtapaAtual DateTime

  observacoes String?            @db.Text
  decisoes    AprovacaoDecisao[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, status, etapaAtual])
  @@index([entidadeTipo, entidadeId])
}

model AprovacaoDecisao {
  id String @id @default(cuid())

  aprovacaoId String
  aprovacao   Aprovacao @relation(fields: [aprovacaoId], references: [id], onDelete: Cascade)

  etapa       Int
  aprovadorId String
  aprovador   User   @relation(fields: [aprovadorId], references: [id], onDelete: Restrict)

  /// 'aprovado' | 'rejeitado'
  decisao String
  motivo  String? @db.Text

  decididoEm DateTime @default(now())

  @@unique([aprovacaoId, etapa])
}

/// Centro de custo hierárquico (DRE / contabilidade gerencial).
model CentroCusto {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  codigo    String
  nome      String
  descricao String? @db.Text

  paiId  String?
  pai    CentroCusto?  @relation("CentroCustoHierarquia", fields: [paiId], references: [id], onDelete: SetNull)
  filhos CentroCusto[] @relation("CentroCustoHierarquia")

  ativo Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movimentos MovimentoFinanceiro[]

  @@unique([workspaceId, codigo])
  @@index([workspaceId, ativo])
}

/// Movimento financeiro — base para DRE e conciliação bancária.
model MovimentoFinanceiro {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  data     DateTime
  /// 'receita' | 'despesa' | 'transferencia'
  tipo     String
  /// 'comissao' | 'frete' | 'corretagem' | 'imposto' | 'salario' | 'outros'
  natureza String

  valor     Decimal @db.Decimal(15, 2)
  descricao String

  centroCustoId String?
  centroCusto   CentroCusto? @relation(fields: [centroCustoId], references: [id], onDelete: SetNull)

  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id], onDelete: SetNull)

  boletoId String?
  boleto   Boleto? @relation(fields: [boletoId], references: [id], onDelete: SetNull)

  safraId String?
  safra   Safra?  @relation(fields: [safraId], references: [id], onDelete: SetNull)

  cultura String?

  conciliado   Boolean   @default(false)
  conciliadoEm DateTime?
  ofxLineHash  String?   @unique

  observacoes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, data])
  @@index([workspaceId, tipo, natureza])
  @@index([centroCustoId])
  @@index([safraId])
}

/// Talhão / Gleba do produtor.
model Talhao {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  produtorId String
  produtor   Cliente @relation(fields: [produtorId], references: [id], onDelete: Cascade)

  nome String
  area Float

  cultura String?
  safraId String?
  safra   Safra?  @relation(fields: [safraId], references: [id], onDelete: SetNull)

  produtividadeEstimadaSc Float?
  produtividadeRealSc     Float?

  latitude  Float?
  longitude Float?
  municipio String?
  uf        String?

  // S4 M1 — vínculo opcional com propriedade rural cadastrada
  propriedadeId String?
  propriedade   PropriedadeRural? @relation(fields: [propriedadeId], references: [id], onDelete: SetNull)

  observacoes String?  @db.Text
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // S5 M9 EUDR — cadeia de custódia
  talhaoLotes TalhaoLote[]

  @@unique([workspaceId, produtorId, nome])
  @@index([workspaceId, ativo])
  @@index([safraId])
  @@index([propriedadeId])
}

/// Royalty de sementes/cultivar (apurado por contrato).
model Royalty {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  contratoId String
  contrato   Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  detentorId String
  detentor   Fornecedor @relation(fields: [detentorId], references: [id], onDelete: Restrict)

  cultivar   String
  qtdSc      Float
  valorPorSc Decimal @db.Decimal(10, 4)
  valorTotal Decimal @db.Decimal(15, 2)

  /// 'apurado' | 'pago' | 'contestado'
  status String @default("apurado")

  pagoEm DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, status])
  @@index([contratoId])
}

// ============================================
// S2 M10 — 2FA, Aceite Digital, Web Push
// ============================================

model Pending2FA {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AceiteContrato {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  contratoId String   @unique
  contrato   Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  tokenHash String @unique

  aceitanteNome    String?
  aceitanteCpfCnpj String?

  aceitoEm        DateTime?
  ipAceite        String?
  userAgentAceite String?

  geoLat Float?
  geoLng Float?

  pdfHashAceito String?

  status String @default("pendente") // 'pendente' | 'aceito' | 'recusado' | 'expirado'

  enviadoEm DateTime @default(now())
  expiraEm  DateTime

  observacoesRecusa String? @db.Text

  @@index([workspaceId, status])
  @@index([tokenHash])
}

model PushSubscription {
  id          String     @id @default(cuid())
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  endpoint String @unique
  p256dh   String
  auth     String

  ativo       Boolean   @default(true)
  ultimoEnvio DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([clienteId])
  @@index([workspaceId])
}

// ============================================
// S3 M3 — ASSINATURA DIGITAL + CLÁUSULAS + NOTIFICAÇÕES
// ============================================

model AssinaturaDigital {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  contratoId String   @unique
  contrato   Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  providerNome  String // 'mock' | 'zapsign' | 'clicksign' | 'd4sign'
  providerDocId String @unique

  authMode String // 'simple' | 'icp_brasil' | 'sms' | 'email_token'

  status String @default("pendente") // 'pendente'|'parcial'|'assinado'|'recusado'|'expirado'|'cancelado'

  enviadoEm    DateTime  @default(now())
  finalizadoEm DateTime?
  expiraEm     DateTime?

  signatarios Json // [{name, cpfCnpj, email, signedAt, refusedAt, ip, ...}]

  pdfOriginalHash String?
  pdfAssinadoUrl  String?
  pdfAssinadoHash String?

  carimboTempo Json? // RFC 3161 timestamp se disponível

  webhookSecret String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, status])
}

model ClausulaContrato {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  templateId String?
  template   ContratoTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  ordem  Int
  tipo   String // 'multa'|'arbitragem'|'foro'|'forca_maior'|'pagamento'|'entrega'|'outras'
  titulo String
  texto  String @db.Text

  obrigatoria Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contratoId])
  @@index([templateId])
}

model ContratoNotificacao {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  contratoId String
  contrato   Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  marco     String // '30d'|'15d'|'7d'|'1d'|'vencido'
  enviadoEm DateTime @default(now())

  @@unique([contratoId, marco])
  @@index([workspaceId])
}

// ============================================
// S4 M1 — Compliance KYC + Propriedades Rurais
// ============================================

/// PropriedadeRural — imóvel rural vinculado a um produtor.
/// Contém matrícula, NIRF/INCRA, CAR (Cadastro Ambiental Rural),
/// georreferenciamento e flags ambientais (embargos, sobreposições).
model PropriedadeRural {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  produtorId String
  produtor   Cliente @relation(fields: [produtorId], references: [id], onDelete: Cascade)

  nome String // "Fazenda Santa Helena"

  // Documentos rurais
  matricula String?
  cartorio  String?
  nirf      String? // Número Identificação Fiscal Imóvel Rural (Receita)
  incra     String? // CCIR INCRA
  itr       String? // ITR (valor pago último ano)

  // CAR — Cadastro Ambiental Rural
  car           String? // AA-NNNNNNN-XXXXXXXX...
  carValidadoEm DateTime?
  carStatus     String? // 'ativo'|'pendente'|'cancelado'|'invalido'|'desconhecido'|'analise'
  carResposta   Json?

  // Áreas (hectares)
  areaTotalHa               Float?
  areaPlantavelHa           Float?
  areaReservaLegal          Float?
  areaPreservacaoPermanente Float? // APP
  areaConsolidada           Float?

  // Georreferenciamento
  geoJson      Json?
  centroideLat Float?
  centroideLng Float?

  // Localização
  municipio String?
  uf        String?

  // Compliance ambiental
  embargoIbama        Boolean   @default(false)
  embargoVerificadoEm DateTime?
  sobreposicaoTI      Boolean   @default(false) // Terra Indígena
  sobreposicaoUC      Boolean   @default(false) // Unidade Conservação
  alertaDesmatamento  Json?

  ativo Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  talhoes Talhao[]

  @@unique([workspaceId, matricula])
  @@index([workspaceId, ativo])
  @@index([produtorId])
  @@index([car])
}

/// ListaSuja — cache local de listas oficiais de sanções (CEIS, CNEP, CEPIM,
/// Trabalho Escravo, PEP, OFAC). Populada por cron periódico para evitar
/// chamadas externas em cada consulta KYC.
model ListaSuja {
  id         String    @id @default(cuid())
  lista      String // 'trabalho_escravo' | 'ceis' | 'cnep' | 'cepim' | 'pep' | 'ofac'
  cnpjOuCpf  String // só dígitos
  nome       String
  uf         String?
  municipio  String?
  detalhes   Json?
  vigenteAte DateTime?

  // Relação opcional com Cliente quando há match exato (auxilia auditoria)
  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  // Workspace é opcional: listas oficiais são globais (workspaceId=null),
  // mas matches gerados por cron podem ser materializados por workspace.
  workspaceId String?

  importadoEm DateTime @default(now())

  @@index([lista, cnpjOuCpf])
  @@index([cnpjOuCpf])
  @@index([clienteId])
}

// ============================================
// S5 M9 — EUDR: Cadeia de custódia + DDS + Áreas Protegidas
// ============================================

/// Cadeia de custódia: liga lote de estoque aos talhões de origem (N:M),
/// opcionalmente apontando o ticket de balança que materializou o aporte.
model TalhaoLote {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  talhaoId String
  talhao   Talhao @relation(fields: [talhaoId], references: [id], onDelete: Cascade)

  loteId String
  lote   LoteEstoque @relation(fields: [loteId], references: [id], onDelete: Cascade)

  qtdSc Float

  ticketBalancaId String?
  ticketBalanca   TicketBalanca? @relation(fields: [ticketBalancaId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@unique([talhaoId, loteId, ticketBalancaId])
  @@index([workspaceId])
  @@index([loteId])
  @@index([talhaoId])
}

/// Catálogo local de áreas protegidas (TI/UC/embargo IBAMA) para checagem
/// de sobreposição com propriedades rurais. Populado por cron mensal.
model AreaProtegida {
  id   String  @id @default(cuid())
  tipo String // 'terra_indigena' | 'unidade_conservacao' | 'embargo_ibama'
  nome String
  uf   String?

  geoJson      Json
  centroideLat Float?
  centroideLng Float?
  bboxJson     Json? // [minLng, minLat, maxLng, maxLat]

  fonte       String // 'funai' | 'icmbio' | 'ibama'
  fonteUrl    String?
  importadoEm DateTime @default(now())

  @@index([tipo, uf])
}

/// Due Diligence Statement — declaração formal exigida pelo EUDR para
/// exportação de commodities relacionadas a desmatamento (soja, café, etc.)
/// para a UE.
model DueDiligenceStatement {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  numero String

  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id], onDelete: SetNull)

  // Operador EUDR (exportador)
  operadorNome     String
  operadorCnpj     String
  operadorEndereco String

  // Produto
  cultura      String
  ncm          String
  qtdToneladas Float

  // Cadeia (snapshots)
  propriedadesOrigem Json // [{ propriedadeId, nome, car, areaHa, geoJson, carStatus, sobreposicao, alertasMapBiomas }]
  lotesEnvolvidos    Json // [{ loteId, numero, qtdSc, talhoesOrigem }]

  // Riscos
  riscoNivel   String // 'baixo' | 'medio' | 'alto' | 'critico'
  riscoFatores Json // [{ tipo, descricao, gravidade }]

  // Atestação
  atestadoPor String?
  atestadoEm  DateTime?

  conclusao String @default("rascunho") // 'rascunho' | 'em_revisao' | 'aprovada' | 'rejeitada' | 'enviada_ue'

  pdfUrl  String?
  pdfHash String?

  eudrSubmissionId String?
  eudrSubmittedAt  DateTime?

  observacoes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, numero])
  @@index([workspaceId, conclusao])
  @@index([contratoId])
}

// ============================================
// EPIC S6 M5 — RISCO PROFISSIONAL
// ============================================

/// Mesa de operações — agrupa corretores (e P&L)
model Mesa {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  nome      String
  descricao String?

  ativo Boolean @default(true)

  corretores Corretor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, ativo])
}

/// Corretor — vincula User opcional, mesa, comissão hierárquica.
model Corretor {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  mesaId String?
  mesa   Mesa?   @relation(fields: [mesaId], references: [id], onDelete: SetNull)

  nome     String
  email    String?
  whatsapp String?
  cpf      String?

  // Comissão hierárquica (% sobre comissão da mesa)
  comissaoPct           Float  @default(0.5)
  comissaoOriginadorPct Float?

  ativo Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, cpf])
  @@index([workspaceId, ativo])
  @@index([mesaId])
  @@index([userId])
}

/// Limite de risco — workspace define escopos/tipos com valor máximo e aviso.
model LimiteRisco {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  /// 'total' | 'cultura' | 'corretor' | 'mesa' | 'contraparte' | 'regiao'
  escopo       String
  /// Filtro JSON do escopo (ex: { cultura: 'soja' } ou { corretorId: 'xxx' })
  escopoFiltro Json?

  /// 'exposicao_usd' | 'exposicao_brl' | 'qtd_sc' | 'var_usd' | 'pnl_neg_usd'
  tipo String

  valorMaximo Decimal  @db.Decimal(15, 2)
  /// Patamar de aviso (ex 80% do valor máximo). Se null usa 80%.
  valorAviso  Decimal? @db.Decimal(15, 2)

  ativo Boolean @default(true)

  observacao String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  breaches LimiteBreach[]

  @@index([workspaceId, escopo, tipo])
  @@index([workspaceId, ativo])
}

/// Breach detectado de um LimiteRisco.
model LimiteBreach {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  limiteId String
  limite   LimiteRisco @relation(fields: [limiteId], references: [id], onDelete: Cascade)

  valorAtual  Decimal @db.Decimal(15, 2)
  valorMaximo Decimal @db.Decimal(15, 2)
  /// Quanto % acima do limite (positivo = excedeu)
  excedidoEm  Decimal @db.Decimal(8, 2)

  /// 'aviso' | 'breach' | 'critico'
  severidade String

  detectadoEm DateTime  @default(now())
  resolvidoEm DateTime?

  triggerEntidade   String?
  triggerEntidadeId String?
  triggerSnapshot   Json?

  /// Notificações enviadas [{canal:'email', enviadoEm}, ...]
  notificadoPor Json?

  observacao String? @db.Text

  @@index([workspaceId, severidade, resolvidoEm])
  @@index([limiteId])
}

// ============================================
// S8 M6 — COMISSÃO HIERÁRQUICA
// ============================================

/// Regra de comissão. Aplicada conforme escopo (tipo + filtro JSON).
/// pctTotal é o % sobre valor do contrato. Distribuição interna via pctCorretor/Originador/Mesa/House.
model ComissaoRegra {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  nome        String
  descricao   String?
  /// 'global' | 'cultura' | 'mesa' | 'corretor' | 'cliente'
  escopoTipo  String?
  /// Filtro JSON do escopo (ex.: { cultura: 'soja' })
  escopoFiltro Json?

  pctTotal      Float
  pctCorretor   Float
  pctOriginador Float?
  pctMesa       Float?
  pctHouse      Float?

  ativo      Boolean @default(true)
  prioridade Int     @default(0)

  apuradas ComissaoApurada[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, ativo, prioridade])
}

/// Comissão apurada para um contrato específico. Imutável após criação (status='apurada').
model ComissaoApurada {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  contratoId String  @unique
  regraId    String?
  regra      ComissaoRegra? @relation(fields: [regraId], references: [id], onDelete: SetNull)

  valorContrato       Decimal @db.Decimal(15, 2)
  pctTotalAplicado    Float
  valorTotalComissao  Decimal @db.Decimal(15, 2)

  corretorId      String?
  valorCorretor   Decimal @default(0) @db.Decimal(15, 2)
  originadorId    String?
  valorOriginador Decimal @default(0) @db.Decimal(15, 2)
  mesaId          String?
  valorMesa       Decimal @default(0) @db.Decimal(15, 2)
  valorHouse      Decimal @default(0) @db.Decimal(15, 2)

  /// 'apurada' | 'paga' | 'cancelada'
  status  String    @default("apurada")
  pagaEm  DateTime?

  createdAt DateTime @default(now())

  @@index([workspaceId, status])
  @@index([corretorId])
}

// ============================================
// S10 M2 — MESA PROFISSIONAL
// Oferta (compra/venda com validade) + CenarioCalculadora (snapshots)
// ============================================

model Oferta {
  id             String    @id @default(cuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  numero         String    @unique @db.VarChar(60)
  tipo           String    @db.VarChar(10) // 'compra' | 'venda'
  cultura        String    @db.VarChar(30) // 'soja' | 'milho' | 'trigo' | ...
  qtdSc          Decimal   @db.Decimal(14, 2)
  precoSc        Decimal   @db.Decimal(10, 2)
  precoMoeda     String    @default("BRL") @db.VarChar(3) // 'BRL' | 'USD'
  origem         String?   @db.VarChar(2)
  destino        String?   @db.VarChar(2)
  validadeHoras  Int       @default(72)
  validaAte      DateTime
  status         String    @default("aberta") @db.VarChar(15) // 'aberta'|'aceita'|'expirada'|'cancelada'
  publica        Boolean   @default(false)
  proprietarioId String
  proprietario   User      @relation("OfertaProprietario", fields: [proprietarioId], references: [id], onDelete: Cascade)
  observacao     String?   @db.Text
  propostaId     String?   @unique
  proposta       Proposta? @relation(fields: [propostaId], references: [id], onDelete: SetNull)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([workspaceId, status, cultura])
  @@index([publica, status])
  @@index([validaAte])
}

model CenarioCalculadora {
  id            String    @id @default(cuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  nome          String    @db.VarChar(120)
  inputJson     Json
  resultadoJson Json
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([workspaceId, userId])
}

/// Configuração global do sistema — key/value JSON.
/// Usado pelo super-admin para flags que afetam o sistema inteiro (ex.: fonte
/// primária de cotações, fallbacks, etc.). NÃO confundir com Workspace settings.
model SystemConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// ============================================================================
// BH GRAIN — Lote 2 (aditivo, sem quebra de contratos existentes)
// Feature flag: SystemConfig.key = 'bhgrain.v1' → { enabled: boolean }
// ============================================================================

/// Inbox unificado — adapter canal-agnóstico sobre WhatsApp/Email/Instagram/Portal.
/// Uma Conversation = uma thread com um cliente/lead num canal específico.
model Conversation {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  channel       String  @db.VarChar(20) // 'whatsapp' | 'email' | 'instagram' | 'portal'
  externalRef   String? @db.VarChar(255) // jid/threadId/conversationId no provedor
  clienteId     String?
  contactName   String?
  contactHandle String? // telefone, e-mail, @instagram

  lastMessageAt DateTime?
  unreadCount   Int       @default(0)
  aiStatus      String    @default("aguardando") // 'aguardando' | 'lida' | 'classificado' | 'pronta_para_proposta' | 'pendente_info' | 'nao_comercial' | 'erro_leitura'

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ConversationMessage[]

  @@unique([workspaceId, channel, externalRef])
  @@index([workspaceId, lastMessageAt])
  @@index([workspaceId, aiStatus])
  @@index([clienteId])
}

model ConversationMessage {
  id             String       @id @default(cuid())
  workspaceId    String
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  externalRef String? @db.VarChar(255)
  direction   String  @db.VarChar(10) // 'in' | 'out'
  text        String? @db.Text
  mediaUrl    String?
  mediaType   String? @db.VarChar(30)

  // Dados extraídos pela IA (JSON livre — score, commodity, qty, etc.)
  aiExtraction Json?
  aiScore      Int?

  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([conversationId, occurredAt])
  @@index([workspaceId, occurredAt])
}

/// Meta comercial mensal por workspace (e opcionalmente por usuário/commodity).
model MetaComercial {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  periodo   String  @db.VarChar(7) // 'YYYY-MM'
  userId    String? // null = meta agregada do workspace
  commodity String? @db.VarChar(40) // null = meta geral

  valorMeta Decimal @db.Decimal(15, 2)
  moeda     String  @default("BRL") @db.VarChar(3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, periodo, userId, commodity])
  @@index([workspaceId, periodo])
}

/// Margem comercial padrão por workspace × commodity.
///
/// Cliente cadastra em /configuracoes/fluxo-trabalho. Cada proposta nova
/// herda este % automaticamente; pode ser sobrescrito caso a caso. O score
/// IA também usa esta margem como referência para classificar 'margem baixa'.
///
/// Exemplo do BH Grain: Soja 0.3%, Milho 0.4%, Trigo 0.5%.
model CommodityMarginRule {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  /// 'soja' | 'milho' | 'trigo' | 'sorgo' | 'algodao' | 'cafe' etc.
  commodity String @db.VarChar(40)

  /// Margem alvo em % do preço (ex.: 0.3 = 0,3%). Decimal(6,3) permite
  /// até 999.999% (overkill mas evita precisão pobre em valores baixos).
  margemPercent Decimal @db.Decimal(6, 3)

  /// Margem mínima aceitável (abaixo dela dispara alerta vermelho na proposta).
  /// Null = sem mínimo definido (só o target).
  margemMinima Decimal? @db.Decimal(6, 3)

  /// Permite documentação interna: "Negociar abaixo de 0,2% requer aprovação."
  observacoes String? @db.Text

  /// Marcador 'ativa' permite manter histórico sem aplicar.
  ativa Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@unique([workspaceId, commodity])
  @@index([workspaceId, ativa])
}

/// Alertas comerciais (margem baixa, cotação vencida, follow-up pendente, etc.).
/// Distinto de AlertaPreco (que é alerta de mercado, não comercial).
model CommercialAlert {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  severity    String  @db.VarChar(15) // 'critico' | 'atencao' | 'informativo'
  category    String  @db.VarChar(40) // 'preco_vencido' | 'margem_baixa' | 'follow_up' | 'concentracao' | 'meta_risco' | 'integracao_erro' | ...
  title       String  @db.VarChar(255)
  description String? @db.Text

  relatedEntityType String? @db.VarChar(30) // 'Proposta' | 'Cliente' | 'Cotacao' | 'Integration' | 'Meta'
  relatedEntityId   String?

  status      String   @default("aberto") @db.VarChar(15) // 'aberto' | 'resolvido' | 'ignorado'
  resolvedAt  DateTime?
  resolvedBy  String?

  createdAt DateTime @default(now())

  @@index([workspaceId, status])
  @@index([workspaceId, severity, status])
  @@index([relatedEntityType, relatedEntityId])
}

/// Regras comerciais configuráveis no /admin (margem mín, validade default, etc.).
model CommercialRule {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  name      String  @db.VarChar(120)
  type      String  @db.VarChar(40) // 'margem_minima' | 'validade_proposta' | 'desconto_max' | 'aprovacao_valor' | 'aprovacao_margem' | 'bloqueio_preco_vencido' | 'follow_up' | 'canal_preferencial'
  commodity String? @db.VarChar(40)
  threshold Decimal? @db.Decimal(15, 4)
  action    String  @db.VarChar(20) // 'alertar' | 'bloquear' | 'aprovar' | 'sugerir'
  params    Json?

  active    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@index([workspaceId, type, active])
}

/// Health check de integrações (WhatsApp/Email/Instagram/Portal/Preços/IA/Financeiro).
model IntegrationHealth {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  integration String @db.VarChar(30) // 'whatsapp' | 'email' | 'instagram' | 'portal' | 'precos' | 'ia' | 'financeiro'
  status      String @db.VarChar(15) // 'online' | 'instavel' | 'atraso' | 'erro' | 'desconectada'

  lastSuccessAt    DateTime?
  lastFailureAt    DateTime?
  responseTimeMs   Int?
  pendingEvents    Int       @default(0)
  processedEvents  Int       @default(0)
  lastErrorMessage String?   @db.Text

  /// Toggle do usuário: quando true, workers e webhooks PARAM de ingerir
  /// eventos desta integração. UI fica cinza. Não deleta credencial,
  /// só bloqueia ingestão temporariamente.
  paused      Boolean   @default(false)
  /// Quando pausedUntil > now, considera-se ainda em pausa.
  /// Permite "pausar até segunda" sem precisar lembrar de reativar.
  /// Null + paused=true = pausa indefinida.
  pausedUntil DateTime?
  pausedBy    String?   // userId que pausou
  pausedReason String?  @db.VarChar(255) // motivo livre opcional

  updatedAt DateTime @updatedAt

  @@unique([workspaceId, integration])
  @@index([workspaceId, status])
  @@index([workspaceId, paused])
}

/// BH Grain Lote 15 — Credenciais de integração por canal × workspace.
/// Segredos (senhas, tokens, apiKeys) ficam em `secretsEncrypted` (JSON map).
/// Cada valor segue formato `iv:tag:cipher` produzido por lib/bhgrain/crypto-secret.
/// Configs públicas (host, porta, usuário, modo) ficam em `config` (Json plain).
///
/// channel valores:
///   'email_imap_smtp' — host, porta, user, useTls + senhas SMTP/IMAP
///   'instagram'       — pageId, instagramBusinessId + pageAccessToken
///   'whatsapp'        — modo central/byo, instanceName, baseUrl, apiKey
model IntegrationCredential {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  channel String @db.VarChar(30)

  /// Provedor configurado. Ex.: 'gmail' | 'outlook' | 'hotmail' | 'custom' (email),
  /// 'meta' (instagram/whatsapp), 'evolution' (whatsapp BYO).
  /// Nulo nas credenciais legadas (migration backfill: 'custom').
  provider String? @db.VarChar(30)

  /// Nome amigável escolhido pelo cliente (ex.: 'Vendas BH', 'Suporte').
  /// Aparece na lista de contas e como tag nas mensagens recebidas.
  displayName String? @db.VarChar(120)

  /// Identificador único da conta dentro do canal: e-mail (IMAP user),
  /// telefone (WhatsApp), pageId (Instagram). Usado no @@unique para
  /// permitir N contas por workspace×canal.
  identifier String? @db.VarChar(255)

  /// Configurações não-sensíveis. Ex.: { imapHost, imapPort, imapUser, smtpHost, smtpPort, smtpUser, useTls, fromName }
  config Json

  /// Segredos criptografados. Map { fieldName: 'iv:tag:cipher' }
  /// Ex.: { imapPassword: 'a1b2c3:...', smtpPassword: 'd4e5f6:...' }
  secretsEncrypted Json

  /// Marcador para UI: usuário ativou esta integração (ou está só salva como rascunho).
  enabled Boolean @default(false)

  /// Última validação bem-sucedida (Test Connection)
  lastTestedAt    DateTime?
  lastTestSuccess Boolean?
  lastTestError   String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  /// Multi-conta por (workspace, canal, identifier). Quando identifier é null
  /// (credenciais legadas single-account), o service layer trata como única.
  @@unique([workspaceId, channel, identifier])
  @@index([workspaceId, enabled])
  @@index([workspaceId, channel, enabled])
}


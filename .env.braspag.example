# ============================================================================
# Braspag API Configuration
# ============================================================================
# IMPORTANT: These are examples only. Get real credentials from Braspag Portal
# DO NOT commit actual credentials to Git
# Use .env.local for local development
# Use .env.production for production values
# ============================================================================

# Braspag Merchant Credentials
# Get these from: Braspag Dashboard → Settings → API Credentials
BRASPAG_MERCHANT_ID=your-merchant-id-here
BRASPAG_MERCHANT_KEY=your-merchant-key-here

# Braspag Webhook Secret
# Create this in: Braspag Dashboard → Settings → Webhooks
# This is used to validate incoming webhook notifications
BRASPAG_WEBHOOK_SECRET=your-webhook-secret-here

# Bank Account Information (Your receiving account)
# This is where customer payments will be received
BRASPAG_BENEFICIARY_AGENCY=0001          # e.g., 0001, 1234
BRASPAG_BENEFICIARY_ACCOUNT=1234567      # Account number
BRASPAG_BENEFICIARY_NAME=MercoGrain LTDA # Company name

# Braspag API URL
# Production: https://api.braspag.com.br
# Sandbox: https://sandbox.braspag.com.br
BRASPAG_API_URL=https://api.braspag.com.br

# Braspag Webhook URL
# This is where Braspag will send payment notifications
# Must be publicly accessible and HTTPS
# Example: https://seu-dominio.com/api/webhooks/braspag
BRASPAG_WEBHOOK_URL=https://seu-dominio.com/api/webhooks/braspag

# ============================================================================
# Setup Instructions
# ============================================================================
#
# 1. Create Braspag Account
#    - Visit https://www.braspag.com.br
#    - Click "Criar Conta" (Create Account)
#    - Verify email
#    - Complete KYC (Know Your Customer) process
#
# 2. Get Credentials
#    - Dashboard → Settings → API Credentials
#    - Copy: Merchant ID and Merchant Key
#    - Dashboard → Settings → Webhooks
#    - Create webhook secret
#
# 3. Configure Bank Account
#    - Dashboard → Settings → Bank Account
#    - Add your receiving bank account
#    - Use values: BRASPAG_BENEFICIARY_*
#
# 4. Register Webhook
#    - Dashboard → Settings → Webhooks
#    - Add URL: https://seu-dominio.com/api/webhooks/braspag
#    - Set header: x-braspag-secret: [your-secret]
#    - Select events to receive
#    - Test webhook (should return 200 OK)
#
# 5. Set Environment Variables
#    - Copy this file to .env.local (development)
#    - Copy this file to .env.production (production)
#    - Fill in actual values from Braspag
#    - NEVER commit to Git
#
# ============================================================================
# Testing
# ============================================================================
#
# Sandbox Testing:
#    1. Change BRASPAG_API_URL to: https://sandbox.braspag.com.br
#    2. Use sandbox credentials
#    3. Test data always succeeds (any CNPJ, future date, any amount)
#    4. Webhook tests won't execute payments
#
# Production:
#    1. Use BRASPAG_API_URL: https://api.braspag.com.br
#    2. Use production credentials from Braspag
#    3. Real payments will be processed
#    4. Webhooks will trigger actual updates
#
# ============================================================================
# Security Best Practices
# ============================================================================
#
# ✅ DO:
#    - Keep secrets in .env.local (never commit)
#    - Rotate merchant keys regularly
#    - Use strong webhook secret (>20 chars)
#    - Monitor webhook logs for unusual activity
#    - Enable 2FA on Braspag account
#    - Use HTTPS only (never HTTP)
#    - Whitelist Braspag IP ranges
#    - Log all boleto transactions
#    - Implement rate limiting
#
# ❌ DON'T:
#    - Commit .env files to Git
#    - Hardcode credentials in code
#    - Use predictable webhook secrets
#    - Accept HTTP webhooks
#    - Expose error messages to users
#    - Store credit card data (use Braspag tokenization)
#    - Skip webhook validation
#    - Ignore failed webhooks
#

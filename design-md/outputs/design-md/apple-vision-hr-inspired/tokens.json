{
  "$schema": "https://design.md/schema/v0.1.0",
  "meta": {
    "name": "VisionGlass",
    "version": "0.1.0",
    "description": "Dark glassmorphism design system inspired by visionOS-style spatial UI. Translucent cards over warm background, oversized display typography, iOS-system accent colors, generous radii.",
    "archetype": "apple-glass",
    "mode": "dark-primary",
    "license": "user-authorized derivative"
  },
  "color": {
    "background": {
      "surface": "#0E0F12",
      "scrim": "rgba(14,15,18,0.55)",
      "ambient": "linear-gradient(135deg, #2A2620 0%, #1A1814 100%)"
    },
    "glass": {
      "card": "rgba(28,28,32,0.62)",
      "cardHover": "rgba(38,38,44,0.72)",
      "cardBorder": "rgba(255,255,255,0.08)",
      "cardBorderStrong": "rgba(255,255,255,0.14)",
      "dock": "rgba(20,20,24,0.78)",
      "dockBorder": "rgba(255,255,255,0.10)",
      "pillTrack": "rgba(255,255,255,0.06)",
      "pillThumb": "rgba(255,255,255,0.18)"
    },
    "foreground": {
      "primary": "#F5F5F7",
      "secondary": "rgba(235,235,245,0.72)",
      "tertiary": "rgba(235,235,245,0.50)",
      "quaternary": "rgba(235,235,245,0.30)",
      "onAccent": "#FFFFFF"
    },
    "accent": {
      "primary": "#0A84FF",
      "primaryHover": "#3B9DFF",
      "primaryMuted": "rgba(10,132,255,0.16)",
      "destructive": "#FF453A",
      "destructiveMuted": "rgba(255,69,58,0.14)",
      "success": "#30D158",
      "successMuted": "rgba(48,209,88,0.16)",
      "warning": "#FF9F0A",
      "info": "#64D2FF"
    },
    "data": {
      "positive": "#30D158",
      "negative": "#FF453A",
      "neutral": "rgba(235,235,245,0.50)"
    }
  },
  "typography": {
    "fontFamily": {
      "display": "'Inter', ui-sans-serif, system-ui, -apple-system, 'Segoe UI', sans-serif",
      "text": "'Inter', ui-sans-serif, system-ui, -apple-system, 'Segoe UI', sans-serif",
      "mono": "'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, monospace"
    },
    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "black": 900
    },
    "scale": {
      "displayXl": { "size": "64px", "lineHeight": "1.04", "weight": 700, "tracking": "-0.025em" },
      "displayLg": { "size": "48px", "lineHeight": "1.08", "weight": 700, "tracking": "-0.02em" },
      "h1":        { "size": "32px", "lineHeight": "1.15", "weight": 700, "tracking": "-0.015em" },
      "h2":        { "size": "24px", "lineHeight": "1.20", "weight": 600, "tracking": "-0.01em" },
      "h3":        { "size": "20px", "lineHeight": "1.30", "weight": 600, "tracking": "-0.005em" },
      "bodyLg":    { "size": "17px", "lineHeight": "1.45", "weight": 400 },
      "body":      { "size": "15px", "lineHeight": "1.47", "weight": 400 },
      "bodySm":    { "size": "13px", "lineHeight": "1.46", "weight": 400 },
      "label":     { "size": "13px", "lineHeight": "1.30", "weight": 500, "tracking": "0" },
      "caption":   { "size": "11px", "lineHeight": "1.36", "weight": 500, "tracking": "0.01em" },
      "metric":    { "size": "28px", "lineHeight": "1.10", "weight": 600, "tracking": "-0.02em", "feature": "'tnum'" }
    }
  },
  "spacing": {
    "unit": "4px",
    "scale": {
      "0": "0px",
      "1": "4px",
      "2": "8px",
      "3": "12px",
      "4": "16px",
      "5": "20px",
      "6": "24px",
      "8": "32px",
      "10": "40px",
      "12": "48px",
      "16": "64px",
      "20": "80px"
    },
    "card": {
      "padding": "20px",
      "paddingLarge": "24px",
      "gap": "16px",
      "gridGap": "12px"
    }
  },
  "radius": {
    "none": "0px",
    "sm": "8px",
    "md": "12px",
    "lg": "16px",
    "xl": "20px",
    "2xl": "24px",
    "pill": "9999px",
    "card": "20px",
    "button": "12px",
    "ctaPill": "9999px",
    "dock": "32px"
  },
  "shadow": {
    "none": "none",
    "card": "0 1px 0 rgba(255,255,255,0.04) inset, 0 8px 24px rgba(0,0,0,0.32)",
    "cardElevated": "0 1px 0 rgba(255,255,255,0.06) inset, 0 16px 40px rgba(0,0,0,0.42)",
    "dock": "0 12px 36px rgba(0,0,0,0.48), 0 1px 0 rgba(255,255,255,0.06) inset",
    "focus": "0 0 0 3px rgba(10,132,255,0.40)",
    "glow": "0 0 24px rgba(10,132,255,0.32)"
  },
  "blur": {
    "card": "32px",
    "dock": "40px",
    "scrim": "20px"
  },
  "border": {
    "width": {
      "hairline": "1px",
      "regular": "1px",
      "thick": "2px"
    }
  },
  "motion": {
    "duration": {
      "instant": "80ms",
      "fast": "160ms",
      "base": "240ms",
      "slow": "400ms",
      "slower": "600ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.4, 0, 0.2, 1)",
      "decelerate": "cubic-bezier(0, 0, 0.2, 1)",
      "accelerate": "cubic-bezier(0.4, 0, 1, 1)",
      "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    }
  },
  "iconSize": {
    "xs": "12px",
    "sm": "14px",
    "md": "16px",
    "lg": "20px",
    "xl": "24px",
    "dock": "20px"
  },
  "avatar": {
    "sm": "24px",
    "md": "32px",
    "lg": "40px",
    "xl": "56px"
  }
}

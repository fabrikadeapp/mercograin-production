# ============================================================================
# TradingView Webhook Configuration
# ============================================================================
# IMPORTANT: These are examples only. Get real secret from your TradingView setup
# DO NOT commit actual secrets to Git
# Use .env.local for local development
# Use .env.production for production values
# ============================================================================

# TradingView Webhook Secret
# This is a custom secret YOU create when setting up alerts in TradingView
# Used to validate that webhooks truly come from TradingView
# Example: A strong random string like: abc123xyz789def456ghi
TRADINGVIEW_WEBHOOK_SECRET=your-webhook-secret-here

# TradingView Webhook URL (for reference)
# This is the public URL where TradingView sends price updates
# Must be HTTPS and publicly accessible
# Example: https://mercograin.com/api/webhooks/tradingview
TRADINGVIEW_WEBHOOK_URL=https://seu-dominio.com/api/webhooks/tradingview

# ============================================================================
# Setup Instructions
# ============================================================================
#
# 1. Create TradingView Alerts
#
#    a) Login to https://www.tradingview.com
#
#    b) Search for: CBOT:ZS (Soja/Soybeans)
#       - Click Alerts (bell icon)
#       - Condition: "Price crosses [your-value]"
#       - Example: "Price crosses above 560"
#
#    c) Set Notification to Webhook:
#       - Enable "Webhook URL" checkbox
#       - Enter: https://seu-dominio.com/api/webhooks/tradingview
#       - Add Header:
#         Name: x-tradingview-secret
#         Value: [your-secret-here]
#
#    d) Payload (copy-paste this JSON):
#       {
#         "ticker": "{{ticker}}",
#         "price": {{close}},
#         "timestamp": {{timenow}},
#         "signal": "buy",
#         "volume": {{volume}},
#         "strength": 75,
#         "description": "Alert from {{ticker}}"
#       }
#
#    e) Save Alert
#
#    f) Repeat for CBOT:ZC (Milho) and CBOT:ZW (Trigo)
#
# 2. Copy This File to .env Files
#
#    For Development:
#    $ cp .env.tradingview.example .env.local
#    $ edit .env.local # fill in your secret
#
#    For Production:
#    $ cp .env.tradingview.example .env.production
#    $ edit .env.production # fill in your secret (same one)
#
# 3. Verify Setup
#
#    a) Start development server:
#       $ npm run dev
#
#    b) In TradingView, click "Test" button on your alert
#
#    c) Check server logs for:
#       "[TradingView] ✅ Cotação salva: soja - 565.50 (USD/BRL: 5.10)"
#
#    d) Verify price appears in API:
#       $ curl https://localhost:3000/api/cotacoes?grao=soja
#
# ============================================================================
# Security Best Practices
# ============================================================================
#
# ✅ DO:
#    - Generate strong secret: `openssl rand -base64 32`
#    - Use HTTPS only (never HTTP)
#    - Change secret every 3-6 months
#    - Keep secret in .env (never commit)
#    - Monitor webhook logs for suspicious patterns
#    - Test alerts regularly
#    - Whitelist your domain in TradingView if possible
#
# ❌ DON'T:
#    - Commit .env files to Git
#    - Use simple/guessable secrets
#    - Accept HTTP webhooks
#    - Share secret in emails/messages
#    - Disable webhook secret validation
#    - Ignore failed webhook deliveries
#    - Use same secret across environments
#
# ============================================================================
# Generating a Strong Secret
# ============================================================================
#
# Method 1: OpenSSL
#   openssl rand -base64 32
#
# Method 2: Node.js
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Method 3: Python
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# Method 4: Online (not recommended for production)
#   https://www.random.org/strings/
#
# ============================================================================
# Symbols
# ============================================================================
#
# ZS   = CBOT:ZS = Soja (Soybeans) - US$/bushel
# ZC   = CBOT:ZC = Milho (Corn) - US$/bushel
# ZW   = CBOT:ZW = Trigo (Wheat) - US$/bushel
#
# Create ONE alert per symbol for best coverage
#
# ============================================================================
# Webhook Endpoint Details
# ============================================================================
#
# Endpoint: POST /api/webhooks/tradingview
# Header Required: x-tradingview-secret
# Content-Type: application/json
# Expected Status: 201 Created
#
# Rate Limiting:
#   - 100 requests per minute per symbol
#   - Returns 429 if exceeded
#
# Deduplication:
#   - 5-minute window (same symbol + timestamp = duplicate)
#   - Returns 409 Conflict if duplicate detected
#
# ============================================================================
# Testing
# ============================================================================
#
# Test webhook with curl:
#
# curl -X POST http://localhost:3000/api/webhooks/tradingview \
#   -H "Content-Type: application/json" \
#   -H "x-tradingview-secret: your-webhook-secret" \
#   -d '{
#     "ticker": "CBOT:ZS",
#     "price": 565.50,
#     "timestamp": '$(date +%s)',
#     "signal": "buy",
#     "volume": 150000,
#     "strength": 75,
#     "description": "Test webhook"
#   }'
#
# Expected Response:
# {
#   "ok": true,
#   "cotacao": { ... },
#   "metadata": { ... }
# }
#
# ============================================================================
# Support & References
# ============================================================================
#
# TradingView Documentation:
#    https://www.tradingview.com/alerts/
#    https://www.tradingview.com/support/
#
# MercoGrain Documentation:
#    - See: docs/TRADINGVIEW_SETUP.md (complete guide)
#    - Tests: __tests__/tradingview-integration.test.ts
#    - Handler: app/api/webhooks/tradingview/route.ts
#    - API: /api/cotacoes (get prices)
#    - Logs: /api/webhooks/logs (view webhook history)
#
# ============================================================================
